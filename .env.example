# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Cloudflare R2
CF_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=chrsd-media
R2_PUBLIC_CDN=https://media.chrsd.org

# Certificate defaults
CERT_SIGNATORY_NAME="Executive Director"
CERT_SIGNATORY_TITLE="CHRSD Foundation"
CHRSD_LOGO_BASE64=

# Email
RESEND_API_KEY=
FROM_EMAIL=noreply@chrsd.org

# Public site
PUBLIC_CONTACT_ENDPOINT=
PUBLIC_NEWSLETTER_ENDPOINT=
