---
import { navigation, site } from '@data/navigation';
import Button from './Button.astro';
const path = Astro.url.pathname;
const isActive = (url: string) => path === url || (url !== '/' && path.startsWith(url));
---
<header class="header" id="site-header">
  <!-- 2.1 Utility Bar -->
  <div class="utility">
    <div class="container utility__inner">
      <a href="/" class="brand" aria-label={`${site.name} home`}>
        <span class="brand__mark" aria-hidden="true">C</span>
        <span class="brand__text">
          <strong>CHRSD</strong>
          <small>Humanitarian Research &amp; Social Development</small>
        </span>
      </a>

      <div class="utility__actions">
        <a class="utility__link" href="/search/" aria-label="Search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" />
            <path d="m20 20-3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
          <span class="utility__label">Search</span>
        </a>

        <div class="lang" role="group" aria-label="Language">
          <a href="/" class="lang__opt lang__opt--active" aria-current="true">EN</a>
          <span aria-hidden="true">/</span>
          <a href="/bn/" class="lang__opt" lang="bn">বাংলা</a>
        </div>

        <Button href={site.donateUrl} variant="donate">Donate</Button>
      </div>
    </div>
  </div>

  <!-- 2.2 Main Navigation -->
  <nav class="mainnav" aria-label="Primary">
    <div class="container mainnav__inner">
      <ul class="mainnav__list">
        {navigation.map((pillar) => (
          <li class="mainnav__item">
            <a
              href={pillar.url}
              class:list={['mainnav__link', { 'is-active': isActive(pillar.url) }]}
              aria-haspopup="true"
              aria-expanded="false"
            >
              {pillar.label}
              <svg class="chev" width="12" height="12" viewBox="0 0 24 24" aria-hidden="true">
                <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>

            <div class="mega" role="region" aria-label={`${pillar.label} menu`}>
              <div class="container mega__inner">
                {pillar.groups.map((group) => (
                  <div class="mega__group">
                    <p class="mega__heading">{group.group}</p>
                    <ul class="mega__links">
                      {group.items.map((item) => (
                        <li><a href={item.url}>{item.label}</a></li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          </li>
        ))}
      </ul>

      <button class="hamburger" id="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-drawer">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile drawer -->
  <div class="drawer" id="mobile-drawer" hidden>
    <div class="drawer__head container">
      <strong>Menu</strong>
      <button class="drawer__close" id="nav-close" aria-label="Close menu">&times;</button>
    </div>
    <nav class="drawer__nav container" aria-label="Mobile primary">
      {navigation.map((pillar) => (
        <details class="acc">
          <summary>{pillar.label}</summary>
          <div class="acc__body">
            <a href={pillar.url} class="acc__overview">All {pillar.label} &rarr;</a>
            {pillar.groups.map((group) => (
              <div class="acc__group">
                <p class="acc__heading">{group.group}</p>
                {group.items.map((item) => <a href={item.url}>{item.label}</a>)}
              </div>
            ))}
          </div>
        </details>
      ))}
      <div class="drawer__cta">
        <Button href={site.donateUrl} variant="donate" size="lg">Donate</Button>
      </div>
    </nav>
  </div>
</header>

<style>
  .header { position: sticky; top: 0; z-index: var(--z-header); background: #fff; }

  /* Utility bar */
  .utility { background: var(--color-forest); color: #fff; }
  .utility__inner { display: flex; align-items: center; justify-content: space-between; min-height: 64px; gap: 16px; }

  .brand { display: flex; align-items: center; gap: 12px; color: #fff; }
  .brand:hover { color: #fff; }
  .brand__mark {
    width: 40px; height: 40px; flex: none;
    display: grid; place-items: center;
    background: var(--color-institutional);
    border-radius: 9px;
    font-family: var(--font-display); font-weight: 800; font-size: 22px; color: #fff;
  }
  .brand__text { display: flex; flex-direction: column; line-height: 1.1; }
  .brand__text strong { font-family: var(--font-display); font-size: 19px; letter-spacing: 0.02em; }
  .brand__text small { font-size: 11px; color: rgba(255, 255, 255, 0.7); }

  .utility__actions { display: flex; align-items: center; gap: 18px; }
  .utility__link { display: inline-flex; align-items: center; gap: 7px; color: rgba(255, 255, 255, 0.85); font-size: 14px; }
  .utility__link:hover { color: #fff; }

  .lang { display: inline-flex; align-items: center; gap: 8px; color: rgba(255, 255, 255, 0.5); font-size: 14px; }
  .lang__opt { color: rgba(255, 255, 255, 0.7); font-weight: 500; }
  .lang__opt:hover { color: #fff; }
  .lang__opt--active { color: #fff; font-weight: 700; }

  /* Main nav */
  .mainnav { border-bottom: 1px solid var(--color-border-green); background: #fff; }
  .mainnav__inner { display: flex; align-items: center; justify-content: space-between; }
  .mainnav__list { display: flex; list-style: none; padding: 0; }
  .mainnav__item { position: static; }

  .mainnav__link {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 20px 18px;
    font-family: var(--font-display); font-weight: 600; font-size: 15px;
    color: var(--color-ink);
    border-bottom: 3px solid transparent;
  }
  .mainnav__link:hover, .mainnav__link.is-active { color: var(--color-institutional); border-bottom-color: var(--color-institutional); }
  .chev { transition: transform var(--dur) var(--ease); }
  .mainnav__item:hover .chev, .mainnav__item:focus-within .chev { transform: rotate(180deg); }

  /* Mega menu */
  .mega {
    position: absolute; left: 0; right: 0;
    background: #fff;
    border-bottom: 4px solid var(--color-institutional);
    box-shadow: var(--shadow-card-hover);
    opacity: 0; visibility: hidden; transform: translateY(8px);
    transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease), visibility var(--dur);
    z-index: var(--z-megamenu);
  }
  .mainnav__item:hover .mega, .mainnav__item:focus-within .mega {
    opacity: 1; visibility: visible; transform: translateY(0);
  }
  .mega__inner { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; padding-block: 36px; }
  .mega__heading {
    font-family: var(--font-display); font-weight: 700; font-size: 13px;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-gold);
    padding-bottom: 12px; margin-bottom: 14px;
    border-bottom: 1px solid var(--color-border-green);
  }
  .mega__links { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .mega__links a { color: var(--color-slate); font-size: 15px; font-weight: 500; }
  .mega__links a:hover { color: var(--color-institutional); }

  /* Hamburger */
  .hamburger { display: none; background: none; border: 0; padding: 12px; cursor: pointer; }
  .hamburger span { display: block; width: 24px; height: 2px; background: var(--color-ink); border-radius: 2px; transition: 0.3s; }
  .hamburger span + span { margin-top: 5px; }

  /* Drawer */
  .drawer { position: fixed; inset: 0; top: 0; background: #fff; z-index: var(--z-megamenu); overflow-y: auto; }
  .drawer[hidden] { display: none; }
  .drawer__head { display: flex; align-items: center; justify-content: space-between; height: 64px; border-bottom: 1px solid var(--color-border-green); }
  .drawer__head strong { font-family: var(--font-display); font-size: 18px; }
  .drawer__close { font-size: 32px; background: none; border: 0; line-height: 1; cursor: pointer; color: var(--color-ink); }
  .drawer__nav { padding-block: 12px 40px; }

  .acc { border-bottom: 1px solid var(--color-border-green); }
  .acc summary { font-family: var(--font-display); font-weight: 600; font-size: 17px; padding: 16px 4px; cursor: pointer; list-style: none; }
  .acc summary::-webkit-details-marker { display: none; }
  .acc summary::after { content: "+"; float: right; color: var(--color-institutional); font-size: 22px; }
  .acc[open] summary::after { content: "\2212"; }
  .acc__body { padding: 0 4px 16px; }
  .acc__overview { display: block; color: var(--color-institutional); font-weight: 600; margin-bottom: 12px; }
  .acc__group + .acc__group { margin-top: 16px; }
  .acc__heading { font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-gold); font-weight: 700; margin-bottom: 8px; }
  .acc__group a { display: block; color: var(--color-slate); padding: 6px 0; font-size: 15px; }
  .drawer__cta { margin-top: 28px; }
  .drawer__cta :global(.btn) { width: 100%; }

  @media (max-width: 1024px) {
    .mainnav__list { display: none; }
    .hamburger { display: block; }
    .brand__text small { display: none; }
  }
  @media (max-width: 480px) {
    .utility__label { display: none; }
    .utility__actions { gap: 12px; }
  }
</style>

<script>
  // Mobile drawer toggle
  const toggle = document.getElementById('nav-toggle');
  const closeBtn = document.getElementById('nav-close');
  const drawer = document.getElementById('mobile-drawer');

  function openDrawer() {
    drawer?.removeAttribute('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    (drawer?.querySelector('.drawer__close') as HTMLElement)?.focus();
  }
  function closeDrawer() {
    drawer?.setAttribute('hidden', '');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    toggle?.focus();
  }
  toggle?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);

  // Esc closes drawer + any open desktop mega-menu (4.2 keyboard requirement)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (drawer && !drawer.hasAttribute('hidden')) closeDrawer();
      const active = document.activeElement as HTMLElement | null;
      active?.blur();
    }
  });
</script>
