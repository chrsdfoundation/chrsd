---
import { getCollection } from 'astro:content';
import Card from './Card.astro';
import Button from './Button.astro';

const all = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const fmt = (d: Date) => d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---
<section class="section section--alt updates">
  <div class="container">
    <div class="updates__head">
      <div>
        <p class="overline">Newsroom</p>
        <h2>Latest Updates</h2>
      </div>
      <Button href="/stay-informed/news/" variant="ghost">Find out more &rarr;</Button>
    </div>

    <div class="updates__grid">
      {all.map((item) => (
        <Card
          href={item.data.externalUrl ?? `/stay-informed/news/${item.slug}/`}
          image={item.data.coverImage}
          alt={item.data.coverAlt}
          tag={item.data.type}
          title={item.data.title}
          excerpt={item.data.excerpt}
          meta={fmt(item.data.pubDate)}
        />
      ))}
    </div>

    <div class="updates__foot">
      <Button href="/stay-informed/news/" variant="outline">All news &amp; press</Button>
    </div>
  </div>
</section>

<style>
  .updates__head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 36px; }
  .updates__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .updates__foot { display: flex; justify-content: center; margin-top: 40px; }

  @media (max-width: 1024px) { .updates__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .updates__grid { grid-template-columns: 1fr; } .updates__head { flex-direction: column; align-items: flex-start; } }
</style>
