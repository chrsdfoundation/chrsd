---
// 2.1 Floating Social Share Sidebar — left edge, vertically centred.
// Share URLs are built client-side from the current page so every page shares
// itself. Hidden on tablet/mobile to keep content width.
const site = 'https://www.chrsd.org';
---
<aside class="social-sidebar" aria-label="Share this page">
  <a class="ss__link" data-share="linkedin" href={`https://www.linkedin.com/sharing/share-offsite/?url=${site}`} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn">
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M4.98 3.5A2.5 2.5 0 1 1 0 3.51 2.5 2.5 0 0 1 4.98 3.5zM.24 8.25h4.5V24h-4.5zM8.5 8.25H12.8v2.15h.06c.6-1.13 2.07-2.32 4.26-2.32 4.56 0 5.4 3 5.4 6.9V24h-4.5v-6.5c0-1.55-.03-3.55-2.16-3.55-2.17 0-2.5 1.7-2.5 3.44V24H8.5z"/></svg>
  </a>
  <a class="ss__link" data-share="x" href={`https://x.com/intent/tweet?url=${site}`} target="_blank" rel="noopener noreferrer" aria-label="Share on X">
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M18.24 2H21.5l-7.4 8.46L22.8 22h-6.78l-5.31-6.94L4.64 22H1.38l7.92-9.05L1.2 2h6.95l4.8 6.35L18.24 2zm-1.19 18h1.8L7.04 3.9H5.1L17.05 20z"/></svg>
  </a>
  <a class="ss__link" data-share="facebook" href={`https://facebook.com/sharer.php?u=${site}`} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6 4.39 10.98 10.13 11.88v-8.4H7.08v-3.48h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.48h-2.8V24C19.61 23.05 24 18.07 24 12.07z"/></svg>
  </a>
</aside>

<style>
  .social-sidebar {
    position: fixed;
    left: 0; top: 50%; transform: translateY(-50%);
    display: flex; flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-border-green);
    border-left: 0;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    box-shadow: var(--shadow-card);
    z-index: var(--z-sidebar);
    overflow: hidden;
  }
  .ss__link {
    width: 44px; height: 44px;
    display: grid; place-items: center;
    color: var(--color-slate);
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .ss__link + .ss__link { border-top: 1px solid var(--color-border-green); }
  .ss__link:hover { background: var(--color-institutional); color: #fff; }

  @media (max-width: 1024px) { .social-sidebar { display: none; } }
</style>

<script>
  // Rewrite share links to point at the current page.
  const url = encodeURIComponent(window.location.href);
  document.querySelectorAll<HTMLAnchorElement>('.ss__link').forEach((a) => {
    const type = a.dataset.share;
    if (type === 'linkedin') a.href = `https://www.linkedin.com/sharing/share-offsite/?url=${url}`;
    if (type === 'x') a.href = `https://x.com/intent/tweet?url=${url}`;
    if (type === 'facebook') a.href = `https://facebook.com/sharer.php?u=${url}`;
  });
</script>
