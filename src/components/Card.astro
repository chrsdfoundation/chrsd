---
interface Props {
  href: string;
  image: string;
  alt: string;
  tag?: string;
  title: string;
  excerpt?: string;
  meta?: string;
  cta?: string;
}
const { href, image, alt, tag, title, excerpt, meta, cta = 'Read more' } = Astro.props;
---
<article class="card">
  <a class="card__media" href={href} tabindex="-1" aria-hidden="true">
    <img src={image} alt={alt} width="640" height="360" loading="lazy" />
    {tag && <span class="card__tag">{tag}</span>}
  </a>
  <div class="card__body">
    {meta && <p class="meta card__meta">{meta}</p>}
    <h3 class="card__title"><a href={href}>{title}</a></h3>
    {excerpt && <p class="card__excerpt">{excerpt}</p>}
    <span class="card__cta">{cta} <span aria-hidden="true">&rarr;</span></span>
  </div>
</article>

<style>
  .card {
    display: flex; flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-border-green);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  .card:hover { transform: translateY(-4px); box-shadow: var(--shadow-card-hover); }

  .card__media { position: relative; display: block; aspect-ratio: 16 / 9; overflow: hidden; }
  .card__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 500ms var(--ease); }
  .card:hover .card__media img { transform: scale(1.05); }
  .card__tag {
    position: absolute; top: 12px; left: 12px;
    background: var(--color-institutional); color: #fff;
    font-family: var(--font-display); font-size: 12px; font-weight: 600;
    padding: 5px 12px; border-radius: var(--radius-pill);
    letter-spacing: 0.02em;
  }

  .card__body { padding: 22px; display: flex; flex-direction: column; flex: 1; }
  .card__meta { margin-bottom: 8px; }
  .card__title { font-size: 20px; line-height: 1.3; }
  .card__title a { color: var(--color-ink); }
  .card__title a:hover { color: var(--color-institutional); }
  .card__excerpt { color: var(--text-muted); font-size: 15px; margin-top: 10px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .card__cta {
    margin-top: auto; padding-top: 16px;
    font-family: var(--font-display); font-weight: 600; font-size: 14px;
    color: var(--color-institutional);
  }
  .card:hover .card__cta { color: var(--color-light-green); }
</style>
