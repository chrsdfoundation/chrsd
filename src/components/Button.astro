---
interface Props {
  href: string;
  variant?: 'solid' | 'outline' | 'donate' | 'ghost';
  size?: 'md' | 'lg';
  external?: boolean;
  class?: string;
}
const { href, variant = 'solid', size = 'md', external = false, class: cls = '' } = Astro.props;
const rel = external ? 'noopener noreferrer' : undefined;
const target = external ? '_blank' : undefined;
---
<a
  href={href}
  class:list={['btn', `btn--${variant}`, `btn--${size}`, cls]}
  rel={rel}
  target={target}
>
  <span><slot /></span>
  {external && <span class="visually-hidden">(opens in a new tab)</span>}
</a>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: var(--font-display);
    font-weight: 600;
    line-height: 1;
    border-radius: var(--radius-pill);
    border: 2px solid transparent;
    cursor: pointer;
    transition: transform var(--dur) var(--ease), background var(--dur) var(--ease),
      color var(--dur) var(--ease), border-color var(--dur) var(--ease);
    white-space: nowrap;
  }
  .btn:hover { transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  .btn--md { padding: 12px 22px; font-size: 15px; }
  .btn--lg { padding: 16px 30px; font-size: 17px; }

  .btn--solid { background: var(--color-institutional); color: #fff; }
  .btn--solid:hover { background: var(--color-light-green); color: #fff; }

  .btn--outline {
    background: transparent;
    color: var(--color-institutional);
    border-color: var(--color-institutional);
  }
  .btn--outline:hover { background: var(--color-institutional); color: #fff; }

  /* On dark sections, outline buttons go white */
  :global(.section--dark) .btn--outline { color: #fff; border-color: rgba(255, 255, 255, 0.6); }
  :global(.section--dark) .btn--outline:hover { background: #fff; color: var(--color-forest); border-color: #fff; }

  /* Donate — Coral reserved exclusively per spec */
  .btn--donate { background: var(--color-donate); color: #fff; }
  .btn--donate:hover { background: var(--color-donate-hover); color: #fff; }

  .btn--ghost { background: transparent; color: var(--color-ink); }
  .btn--ghost:hover { color: var(--color-institutional); }
  :global(.section--dark) .btn--ghost { color: #fff; }
</style>
