---
import '@styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import SocialSidebar from '@components/SocialSidebar.astro';
import CookieConsent from '@components/CookieConsent.astro';
import { site } from '@data/navigation';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}
const {
  title,
  description = 'CHRSD — Centre for Humanitarian Research and Social Development Foundation. Human rights advocacy, climate resilience, and community development in Bangladesh.',
  image = '/images/og-default.jpg',
  noindex = false,
} = Astro.props;

const fullTitle = title === 'Home' ? `${site.name} — There's always a way` : `${title} | ${site.name}`;
const canonical = new URL(Astro.url.pathname, site.url).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, site.url).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, site.url).href} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="bn" href={new URL('/bn' + Astro.url.pathname, site.url).href} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- JSON-LD: Organisation -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "NGO",
      "name": site.legalName,
      "alternateName": site.name,
      "url": site.url,
      "logo": new URL('/images/chrsd-seal.png', site.url).href,
      "foundingDate": String(site.founded),
      "description": "Human rights advocacy, climate resilience, and community development in Bangladesh.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "29 Toyenbee Circular Road (5th Floor)",
        "addressLocality": "Dhaka",
        "addressCountry": "BD"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "email": site.email,
        "telephone": site.phone,
        "contactType": "general"
      },
      "sameAs": Object.values(site.social)
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: Plus Jakarta Sans (display) + Inter (body). Preconnect for LCP. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap"
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <SocialSidebar />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CookieConsent />

    <!-- Sticky header shadow on scroll -->
    <script>
      const header = document.getElementById('site-header');
      const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 8);
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    </script>
    <style is:global>
      #site-header.is-scrolled { box-shadow: 0 4px 20px rgba(13, 31, 13, 0.08); }
    </style>
  </body>
</html>
