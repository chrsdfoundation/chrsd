---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import AboutSection from '@components/AboutSection.astro';
import StatsBlock from '@components/StatsBlock.astro';
import ImpactSummary from '@components/ImpactSummary.astro';
import NewsCards from '@components/NewsCards.astro';
import Card from '@components/Card.astro';
import Button from '@components/Button.astro';
import { getCollection } from 'astro:content';

// Featured programmes for a homepage "Our Work" teaser row
const featured = (await getCollection('projects', ({ data }) => data.featured))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
const projects = featured.length
  ? featured
  : (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order).slice(0, 3);
---
<BaseLayout title="Home">
  <!-- Block 2: Hero carousel -->
  <Hero />

  <!-- Proof strip: trust signals -->
  <div class="proof-strip">
    <div class="container proof-strip__inner">
      <span class="proof-item">Reg No. S-14480/2026</span>
      <span class="proof-sep" aria-hidden="true">·</span>
      <span class="proof-item">NSADMP — National afforestation programme</span>
      <span class="proof-sep" aria-hidden="true">·</span>
      <span class="proof-item">SDAMSMP — Digital school attendance</span>
      <span class="proof-sep" aria-hidden="true">·</span>
      <span class="proof-item">AI Vision Care — 1.2M RMG workers</span>
    </div>
  </div>

  <!-- Block 3: About CHRSD -->
  <AboutSection />

  <!-- Block 4: Unlocking Potential stats -->
  <StatsBlock />

  <!-- Our Work teaser (programmes collection) -->
  <section class="section work-teaser">
    <div class="container">
      <div class="work-teaser__head">
        <div>
          <p class="overline">Our work</p>
          <h2>Programmes engineered with communities</h2>
        </div>
        <Button href="/our-work/" variant="ghost">View all programmes &rarr;</Button>
      </div>
      <div class="work-teaser__grid">
        {projects.map((p) => (
          <Card
            href={`/our-work/${p.slug}/`}
            image={p.data.coverImage}
            alt={p.data.coverAlt}
            tag={p.data.focusArea}
            title={p.data.title}
            excerpt={p.data.summary}
            meta={`${p.data.country}${p.data.startYear ? ` · since ${p.data.startYear}` : ''}`}
            cta="Explore programme"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Block 6: Impact summary banner -->
  <ImpactSummary />

  <!-- For Donors & Partners CTA -->
  <section class="section section--alt donors-cta">
    <div class="container donors-cta__inner">
      <div class="donors-cta__block">
        <p class="overline">For Donors</p>
        <h3>Support communities that need it most</h3>
        <p>Your contribution funds climate resilience, human rights work, and community development across Bangladesh.</p>
        <Button href="/donate/" variant="donate" size="lg">Donate now</Button>
      </div>
      <div class="donors-cta__divider" aria-hidden="true"></div>
      <div class="donors-cta__block">
        <p class="overline">For Partners</p>
        <h3>Build a formalised partnership</h3>
        <p>We work with government bodies, civil society, and the private sector through structured MOU-backed collaborations.</p>
        <Button href="/get-involved/partnership/" variant="solid" size="lg">Explore partnership</Button>
      </div>
    </div>
  </section>

  <!-- Block 7: Latest Updates (news) -->
  <NewsCards />
</BaseLayout>

<style>
  .work-teaser__head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 36px; }
  .work-teaser__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  @media (max-width: 1024px) { .work-teaser__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .work-teaser__grid { grid-template-columns: 1fr; } .work-teaser__head { flex-direction: column; align-items: flex-start; } }

  /* Proof strip */
  .proof-strip { background: var(--color-forest); border-top: 1px solid rgba(255,255,255,0.1); }
  .proof-strip__inner { display: flex; flex-wrap: wrap; align-items: center; gap: 12px 20px; padding-block: 14px; }
  .proof-item { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.75); white-space: nowrap; }
  .proof-sep { color: rgba(255,255,255,0.3); }

  /* Donors & Partners CTA */
  .donors-cta__inner { display: grid; grid-template-columns: 1fr auto 1fr; gap: 48px; align-items: center; }
  .donors-cta__block h3 { margin-top: 10px; }
  .donors-cta__block p { margin-top: 10px; color: var(--color-slate); max-width: 42ch; }
  .donors-cta__block :global(.btn) { margin-top: 24px; }
  .donors-cta__divider { width: 1px; height: 180px; background: var(--color-border-green); }
  @media (max-width: 860px) {
    .donors-cta__inner { grid-template-columns: 1fr; }
    .donors-cta__divider { width: 100%; height: 1px; }
  }
</style>
