---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import { site } from '@data/navigation';
const endpoint = import.meta.env.PUBLIC_CONTACT_ENDPOINT || '';
---
<BaseLayout
  title="Contact Us"
  description="Get in touch with CHRSD — partnerships, media, programmes, and general enquiries."
>
  <PageHero
    overline="Get involved"
    title="Get in touch"
    lead="Whether you're a partner, journalist, or someone who wants to help — we'd like to hear from you."
  />

  <section class="section">
    <div class="container contact">
      <div class="contact__info">
        <h2>Reach us directly</h2>
        <dl class="contact__list">
          <div>
            <dt>Office</dt>
            <dd>{site.address}</dd>
          </div>
          <div>
            <dt>Email</dt>
            <dd><a href={`mailto:${site.email}`}>{site.email}</a></dd>
          </div>
          <div>
            <dt>Phone</dt>
            <dd><a href={`tel:${site.phone.replace(/[^+\d]/g, '')}`}>{site.phone}</a></dd>
          </div>
          <div>
            <dt>Hours</dt>
            <dd>Sunday&ndash;Thursday, 9:00&ndash;17:00 (GMT+6)</dd>
          </div>
        </dl>
        <p class="contact__note">
          For procurement and tenders, please visit the
          <a href={site.tenderUrl} target="_blank" rel="noopener noreferrer">E-Tender portal</a>.
        </p>
      </div>

      <form class="contact__form" id="contact-form" action={endpoint} method="POST" novalidate>
        <div class="field">
          <label for="name">Full name <span aria-hidden="true">*</span></label>
          <input id="name" name="name" type="text" required autocomplete="name" aria-required="true" />
          <p class="error" data-error-for="name"></p>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="email">Email <span aria-hidden="true">*</span></label>
            <input id="email" name="email" type="email" required autocomplete="email" aria-required="true" />
            <p class="error" data-error-for="email"></p>
          </div>
          <div class="field">
            <label for="org">Organisation</label>
            <input id="org" name="organisation" type="text" autocomplete="organization" />
          </div>
        </div>

        <div class="field">
          <label for="topic">What is this about?</label>
          <select id="topic" name="topic">
            <option value="General enquiry">General enquiry</option>
            <option value="Partnership">Partnership</option>
            <option value="Media & press">Media &amp; press</option>
            <option value="Volunteering">Volunteering</option>
            <option value="Programmes">Programmes</option>
          </select>
        </div>

        <div class="field">
          <label for="message">Message <span aria-hidden="true">*</span></label>
          <textarea id="message" name="message" rows="6" required aria-required="true"></textarea>
          <p class="error" data-error-for="message"></p>
        </div>

        <!-- Honeypot for spam bots -->
        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="visually-hidden" aria-hidden="true" />

        <button type="submit" class="submit">Send message</button>
        <p class="form-status" role="status" aria-live="polite" data-status></p>
      </form>
    </div>
  </section>

  <!-- EMAIL DIRECTORY -->
  <section class="section section--alt">
    <div class="container">
      <div class="dir-header">
        <p class="overline">Contacts &amp; routing reference</p>
        <h2>Email Directory</h2>
        <p class="dir-lead">All CHRSD addresses at chrsd.org — click any address to compose, or use the copy button.</p>
      </div>

      <div class="dir-categories">

        <div class="dir-category">
          <p class="dir-cat-label">Public-facing &amp; General Contact</p>
          <div class="dir-cards">
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'info@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:info@chrsd.org">info@chrsd.org</a></div>
              <div class="dir-desc">General inquiries from public</div>
              <span class="dir-route">forward to comms team</span>
            </div>
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'contact@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:contact@chrsd.org">contact@chrsd.org</a></div>
              <div class="dir-desc">Website contact form destination</div>
              <span class="dir-route">alias for info@</span>
            </div>
          </div>
        </div>

        <div class="dir-category">
          <p class="dir-cat-label">Communications &amp; Media</p>
          <div class="dir-cards">
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'media@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:media@chrsd.org">media@chrsd.org</a></div>
              <div class="dir-desc">Press &amp; journalist inquiries</div>
              <span class="dir-route">comms / PR team</span>
            </div>
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'press@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:press@chrsd.org">press@chrsd.org</a></div>
              <div class="dir-desc">Press releases &amp; statements</div>
              <span class="dir-route">alias or same as media@</span>
            </div>
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'newsletter@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:newsletter@chrsd.org">newsletter@chrsd.org</a></div>
              <div class="dir-desc">Subscription &amp; email campaigns</div>
              <span class="dir-route">mailing list platform</span>
            </div>
          </div>
        </div>

        <div class="dir-category">
          <p class="dir-cat-label">Fundraising &amp; Partnerships</p>
          <div class="dir-cards">
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'donate@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:donate@chrsd.org">donate@chrsd.org</a></div>
              <div class="dir-desc">Donation queries &amp; receipts</div>
              <span class="dir-route">finance &amp; donor relations</span>
            </div>
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'grants@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:grants@chrsd.org">grants@chrsd.org</a></div>
              <div class="dir-desc">Grant applications &amp; reporting</div>
              <span class="dir-route">programs / grants manager</span>
            </div>
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'partnerships@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:partnerships@chrsd.org">partnerships@chrsd.org</a></div>
              <div class="dir-desc">Corporate &amp; NGO collaborations</div>
              <span class="dir-route">executive / BD team</span>
            </div>
          </div>
        </div>

        <div class="dir-category">
          <p class="dir-cat-label">Programs &amp; Fieldwork</p>
          <div class="dir-cards">
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'programs@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:programs@chrsd.org">programs@chrsd.org</a></div>
              <div class="dir-desc">Project inquiries &amp; beneficiary support</div>
              <span class="dir-route">program managers</span>
            </div>
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'field@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:field@chrsd.org">field@chrsd.org</a></div>
              <div class="dir-desc">On-ground team communications</div>
              <span class="dir-route">regional coordinators</span>
            </div>
          </div>
        </div>

        <div class="dir-category">
          <p class="dir-cat-label">Human Resources &amp; Volunteers</p>
          <div class="dir-cards">
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'careers@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:careers@chrsd.org">careers@chrsd.org</a></div>
              <div class="dir-desc">Job applications &amp; recruitment</div>
              <span class="dir-route">HR team</span>
            </div>
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'volunteer@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:volunteer@chrsd.org">volunteer@chrsd.org</a></div>
              <div class="dir-desc">Volunteer signup &amp; coordination</div>
              <span class="dir-route">volunteer manager</span>
            </div>
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'hr@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:hr@chrsd.org">hr@chrsd.org</a></div>
              <div class="dir-desc">Staff internal HR matters</div>
              <span class="dir-route">HR director (confidential)</span>
            </div>
          </div>
        </div>

        <div class="dir-category">
          <p class="dir-cat-label">Finance, Legal &amp; Compliance</p>
          <div class="dir-cards">
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'finance@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:finance@chrsd.org">finance@chrsd.org</a></div>
              <div class="dir-desc">Invoices, payments &amp; audits</div>
              <span class="dir-route">CFO / finance team</span>
            </div>
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'legal@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:legal@chrsd.org">legal@chrsd.org</a></div>
              <div class="dir-desc">Contracts, MoUs &amp; compliance</div>
              <span class="dir-route">legal counsel</span>
            </div>
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'compliance@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:compliance@chrsd.org">compliance@chrsd.org</a></div>
              <div class="dir-desc">Regulatory &amp; ethics reporting</div>
              <span class="dir-route">compliance officer</span>
            </div>
          </div>
        </div>

        <div class="dir-category">
          <p class="dir-cat-label">Technology, IT &amp; Security</p>
          <div class="dir-cards">
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'it@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:it@chrsd.org">it@chrsd.org</a></div>
              <div class="dir-desc">Internal tech support &amp; helpdesk</div>
              <span class="dir-route">IT administrator</span>
            </div>
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'security@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:security@chrsd.org">security@chrsd.org</a></div>
              <div class="dir-desc">Cybersecurity &amp; data breach alerts</div>
              <span class="dir-route">security team / CISO</span>
            </div>
          </div>
        </div>

        <div class="dir-category">
          <p class="dir-cat-label">Executive &amp; Governance</p>
          <div class="dir-cards">
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'board@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:board@chrsd.org">board@chrsd.org</a></div>
              <div class="dir-desc">Board of directors communications</div>
              <span class="dir-route">board secretary</span>
            </div>
            <div class="dir-card">
              <button class="dir-copy" onclick="copyEmail(this,'ed@chrsd.org')" type="button">Copy</button>
              <div class="dir-email"><a href="mailto:ed@chrsd.org">ed@chrsd.org</a></div>
              <div class="dir-desc">Executive director office</div>
              <span class="dir-route">executive assistant</span>
            </div>
          </div>
        </div>

      </div>

      <p class="dir-footer">All addresses @chrsd.org &middot; Click any address to compose a message</p>
    </div>
  </section>
</BaseLayout>

<style>
  .contact { display: grid; grid-template-columns: 1fr 1.4fr; gap: 56px; align-items: start; }
  .contact__info h2 { font-size: 28px; }
  .contact__list { margin-top: 24px; display: grid; gap: 20px; }
  .contact__list dt { font-family: var(--font-display); font-weight: 700; font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-gold); }
  .contact__list dd { margin: 4px 0 0; color: var(--text-body); line-height: 1.5; }
  .contact__note { margin-top: 28px; padding: 16px 18px; background: var(--color-tint); border-left: 3px solid var(--color-institutional); border-radius: var(--radius-sm); font-size: 15px; color: var(--text-muted); }

  .contact__form {
    background: #fff; border: 1px solid var(--color-border-green);
    border-radius: var(--radius); padding: 36px;
  }
  .field { margin-bottom: 20px; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  label { display: block; font-family: var(--font-display); font-weight: 600; font-size: 14px; margin-bottom: 7px; }
  label span { color: var(--color-donate); }
  input, select, textarea {
    width: 100%; padding: 13px 15px;
    border: 1px solid var(--color-border-green); border-radius: var(--radius-sm);
    font-family: var(--font-body); font-size: 16px; color: var(--color-ink); background: #fff;
    transition: border-color var(--dur) var(--ease);
  }
  input:focus, select:focus, textarea:focus { border-color: var(--color-institutional); }
  textarea { resize: vertical; }
  .error { color: #B3261E; font-size: 13px; margin-top: 6px; min-height: 1em; }
  input[aria-invalid='true'], textarea[aria-invalid='true'] { border-color: #B3261E; }

  .submit {
    background: var(--color-institutional); color: #fff; border: 0;
    padding: 15px 32px; border-radius: var(--radius-pill);
    font-family: var(--font-display); font-weight: 600; font-size: 16px; cursor: pointer;
    transition: background var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .submit:hover { background: var(--color-light-green); transform: translateY(-1px); }
  .submit:disabled { opacity: 0.6; cursor: not-allowed; }
  .form-status { margin-top: 14px; font-size: 15px; min-height: 1em; }
  .form-status.is-ok { color: var(--color-institutional); }
  .form-status.is-err { color: #B3261E; }

  @media (max-width: 900px) { .contact { grid-template-columns: 1fr; gap: 36px; } }
  @media (max-width: 560px) { .field-row { grid-template-columns: 1fr; } .contact__form { padding: 24px; } }

  /* Email Directory */
  .dir-header { margin-bottom: 40px; }
  .dir-header h2 { margin-top: 12px; }
  .dir-lead { color: var(--color-slate); margin-top: 10px; font-size: 15px; }

  .dir-categories { display: flex; flex-direction: column; gap: 36px; }

  .dir-cat-label {
    font-family: var(--font-display); font-weight: 700; font-size: 11px;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-donate);
    margin-bottom: 14px;
    display: flex; align-items: center; gap: 8px;
  }
  .dir-cat-label::before {
    content: ''; display: inline-block; width: 18px; height: 2px;
    background: var(--color-donate); border-radius: 2px; flex-shrink: 0;
  }

  .dir-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 14px;
  }

  .dir-card {
    background: #fff; border: 1px solid var(--color-border-green);
    border-radius: var(--radius); padding: 16px 18px 14px;
    display: flex; flex-direction: column; gap: 6px;
    position: relative; overflow: hidden;
    transition: box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease), border-color var(--dur) var(--ease);
    cursor: default;
  }
  .dir-card::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 3px; height: 100%;
    background: var(--color-donate); opacity: 0;
    transition: opacity var(--dur) var(--ease);
    border-radius: var(--radius) 0 0 var(--radius);
  }
  .dir-card:hover { box-shadow: var(--shadow-card-hover); transform: translateY(-2px); border-color: transparent; }
  .dir-card:hover::before { opacity: 1; }

  .dir-email { font-family: var(--font-display); font-weight: 700; font-size: 15px; color: var(--color-forest); word-break: break-all; }
  .dir-email a { color: inherit; text-decoration: none; }
  .dir-email a:hover { color: var(--color-donate); }
  .dir-desc { font-size: 13px; color: var(--color-slate); line-height: 1.4; }
  .dir-route {
    display: inline-flex; align-items: center; gap: 4px;
    background: var(--color-tint); color: var(--color-institutional);
    font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 20px;
    margin-top: 2px; width: fit-content;
  }
  .dir-route::before { content: '→'; }

  .dir-copy {
    position: absolute; top: 10px; right: 10px;
    background: none; border: 1px solid var(--color-border-green);
    border-radius: 6px; padding: 3px 8px;
    font-size: 11px; font-family: var(--font-display); font-weight: 600;
    color: var(--color-slate); cursor: pointer;
    opacity: 0; transition: opacity var(--dur), background var(--dur), color var(--dur);
  }
  .dir-card:hover .dir-copy { opacity: 1; }
  .dir-copy:hover { background: var(--color-forest); color: #fff; border-color: var(--color-forest); }
  .dir-copy.copied { background: var(--color-tint); color: var(--color-institutional); border-color: var(--color-tint); opacity: 1; }

  .dir-footer {
    text-align: center; margin-top: 36px; padding-top: 20px;
    border-top: 1px solid var(--color-border-green);
    font-size: 13px; color: var(--color-slate); letter-spacing: 0.02em;
  }

  @media (max-width: 500px) { .dir-cards { grid-template-columns: 1fr; } }
</style>

<script>
  function copyEmail(btn: HTMLButtonElement, email: string) {
    navigator.clipboard.writeText(email).then(() => {
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1800);
    });
  }
  (window as any).copyEmail = copyEmail;

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = form?.querySelector<HTMLElement>('[data-status]');

  function setError(name: string, msg: string) {
    const field = form?.querySelector<HTMLElement>(`[data-error-for="${name}"]`);
    const input = form?.querySelector<HTMLInputElement>(`[name="${name}"]`);
    if (field) field.textContent = msg;
    input?.setAttribute('aria-invalid', msg ? 'true' : 'false');
  }

  function validate(): boolean {
    let ok = true;
    const name = form?.querySelector<HTMLInputElement>('[name="name"]');
    const email = form?.querySelector<HTMLInputElement>('[name="email"]');
    const message = form?.querySelector<HTMLTextAreaElement>('[name="message"]');

    if (!name?.value.trim()) { setError('name', 'Please enter your name.'); ok = false; } else setError('name', '');
    if (!email?.value.trim()) { setError('email', 'Please enter your email.'); ok = false; }
    else if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email.value)) { setError('email', 'Please enter a valid email.'); ok = false; }
    else setError('email', '');
    if (!message?.value.trim()) { setError('message', 'Please write a message.'); ok = false; } else setError('message', '');
    return ok;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (status) { status.textContent = ''; status.className = 'form-status'; }
    if (!validate()) {
      form.querySelector<HTMLElement>('[aria-invalid="true"]')?.focus();
      return;
    }
    if (!form.action) {
      if (status) { status.textContent = 'Demo mode: set PUBLIC_CONTACT_ENDPOINT in .env to enable sending.'; status.classList.add('is-ok'); }
      form.reset();
      return;
    }
    const submitBtn = form.querySelector<HTMLButtonElement>('.submit');
    submitBtn?.setAttribute('disabled', '');
    if (status) status.textContent = 'Sending\u2026';
    try {
      const res = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } });
      if (res.ok) {
        if (status) { status.textContent = 'Thank you \u2014 your message has been sent. We\u2019ll be in touch.'; status.classList.add('is-ok'); }
        form.reset();
      } else {
        if (status) { status.textContent = 'Something went wrong. Please email us directly.'; status.classList.add('is-err'); }
      }
    } catch {
      if (status) { status.textContent = 'Network error. Please try again or email us directly.'; status.classList.add('is-err'); }
    } finally {
      submitBtn?.removeAttribute('disabled');
    }
  });
</script>
