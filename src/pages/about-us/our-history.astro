---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import Button from '@components/Button.astro';

const milestones = [
  {
    year: '2023',
    era: 'Foundation',
    title: 'CHRSD established in Dhaka',
    body: 'The Centre for Humanitarian Research and Social Development Foundation is registered under the Societies Registration Act (Reg. No. S-14480/2026). Founded by researchers and civil society leaders, CHRSD\'s mandate: produce evidence that marginalised communities can use to advocate for their own rights and partner with government on technology-driven development solutions.'
  },
  {
    year: '2023',
    era: 'Research',
    title: 'Socio-economic research and human rights programmes launched',
    body: 'CHRSD launches its socio-economic research division — producing evidence on poverty, labour markets, and environmental change — alongside a human rights monitoring and legal aid programme offering free legal representation to victims of trafficking, domestic violence, and arbitrary detention.'
  },
  {
    year: '2024',
    era: 'Climate',
    title: 'NSADMP submitted to MoEFCC',
    body: 'The National Smart Afforestation & Digital Monitoring Programme is formally submitted to and received by the Ministry of Environment, Forest and Climate Change. NSADMP deploys GIS tagging, Sentinel-2/Landsat-8 NDVI satellite monitoring, and the Nevronus Systems mobile platform to verify sapling survival at tree level across Bangladesh.'
  },
  {
    year: '2024',
    era: 'Governance',
    title: 'SDAMSMP submitted to MoPME',
    body: 'The Smart Digital Attendance Management System & Monitoring Programme is submitted to the Ministry of Primary and Mass Education and the Directorate of Primary Education. The programme targets biometric-verified teacher attendance across 65,566+ government primary schools — covering 379,624 teachers nationally.'
  },
  {
    year: '2025',
    era: 'Partnership',
    title: 'AI Vision Care Initiative — BGMEA acknowledgement',
    body: 'CHRSD, in partnership with Nevronus Systems and optical technology partner Lunera Eye Care, secures a signed acknowledgement from BGMEA for the AI Vision Care Initiative — deploying AI-assisted computer vision diagnostics to address uncorrected vision impairment among 1.2 million RMG garment workers.'
  },
  {
    year: '2026',
    era: 'Milestone',
    title: 'Community tree planting drive — Sonaimuri 2026',
    body: 'CHRSD\'s first large-scale community plantation drive plants over 5,000 GPS-tagged saplings in Sonaimuri, directly supporting the Government of Bangladesh\'s national electoral pledge to plant 25 crore trees within five years under the "5 Bochore 25 Koti Brikkhyaropon" programme.'
  },
  {
    year: '2026',
    era: 'Future',
    title: 'NSADMP Phase II and coastal expansion',
    body: 'CHRSD launches Phase II of NSADMP targeting coastal Bangladesh, where climate stress is most acute. The legal aid programme expands to three new districts and a multi-year evaluation of SDAMSMP begins — measuring whether attendance improvements translate into learning outcomes.'
  },
];
---
<BaseLayout
  title="Our History & Milestones"
  description="CHRSD's history and milestones from our founding in 2023 to the present."
>
  <PageHero
    overline="About · Our identity"
    title="Our history & milestones"
    lead="From our founding in 2023 to a multi-programme foundation operating across fourteen districts — this is the story of how CHRSD grew into the work."
  />

  <!-- FOUNDING SECTION -->
  <section class="section">
    <div class="container founding">
      <div class="founding__text">
        <p class="overline">The beginning</p>
        <h2>Founded to bridge evidence and community action</h2>
        <p class="lead" style="margin-top:14px">
          CHRSD was established in 2023 by researchers and civil society leaders in Dhaka.
          The founders believed Bangladesh needed independent, evidence-based institutions
          capable of holding power accountable and amplifying the voices of the most vulnerable.
        </p>
        <p style="margin-top:16px;color:var(--color-slate)">
          In just a few years, CHRSD has grown from a founding idea into a multi-programme
          foundation with formal submissions to two government ministries. The question —
          <em>what does it take for marginalised people to shape their own futures?</em>
          — remains exactly the same.
        </p>
      </div>
      <div class="founding__stat">
        <span class="founding__year">2023</span>
        <span class="founding__label">Year founded</span>
        <span class="founding__sub">Community-centred development from day one</span>
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="section section--alt">
    <div class="container">
      <p class="overline">Key milestones</p>
      <h2>Our milestones</h2>
      <div class="timeline" role="list">
        {milestones.map((m, i) => (
          <article class="milestone" role="listitem">
            <div class="milestone__year-col" aria-hidden="true">
              <span class="milestone__year">{m.year}</span>
              <span class="milestone__line"></span>
            </div>
            <div class="milestone__content">
              <span class="milestone__era">{m.era}</span>
              <h3 class="milestone__title">{m.title}</h3>
              <p class="milestone__body">{m.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--dark">
    <div class="container cta__inner">
      <div>
        <p class="overline">Where we are headed</p>
        <h2 style="color:#fff;margin-top:10px">The next chapter</h2>
        <p style="color:rgba(255,255,255,0.82);margin-top:12px;max-width:52ch">
          Read our Executive Director's annual message for a detailed account of this
          year's progress and CHRSD's priorities for the years ahead.
        </p>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:14px;flex-shrink:0">
        <Button href="/about-us/executive-directors-message/" variant="solid">Director's message</Button>
        <Button href="/impact/annual-reports/" variant="outline">Annual reports</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Founding */
  .founding { display: grid; grid-template-columns: 1fr auto; gap: 56px; align-items: center; }
  .founding__text h2 { margin-top: 12px; }
  .founding__stat {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    width: 200px; height: 200px; border-radius: 50%;
    background: var(--color-forest); flex-shrink: 0;
  }
  .founding__year { font-family: var(--font-display); font-weight: 800; font-size: 52px; color: #fff; line-height: 1; }
  .founding__label { font-family: var(--font-display); font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.7); margin-top: 4px; }
  .founding__sub { font-size: 11px; color: rgba(255,255,255,0.55); max-width: 120px; text-align: center; margin-top: 6px; line-height: 1.4; }

  /* Timeline */
  .timeline { display: grid; gap: 0; margin-top: 44px; }
  .milestone { display: grid; grid-template-columns: 100px 1fr; gap: 32px; padding-bottom: 40px; }
  .milestone:last-child .milestone__line { display: none; }

  .milestone__year-col { display: flex; flex-direction: column; align-items: center; padding-top: 6px; }
  .milestone__year { font-family: var(--font-display); font-weight: 800; font-size: 18px; color: var(--color-institutional); flex-shrink: 0; }
  .milestone__line { flex: 1; width: 2px; background: var(--color-border-green); margin-top: 10px; min-height: 40px; }

  .milestone__content { background: #fff; border: 1px solid var(--color-border-green); border-radius: var(--radius); padding: 24px 28px; }
  .milestone__era { font-family: var(--font-display); font-weight: 700; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-gold); }
  .milestone__title { font-size: 19px; color: var(--color-forest); margin: 8px 0 10px; }
  .milestone__body { font-size: 15px; color: var(--color-slate); line-height: 1.7; }

  /* CTA */
  .cta__inner { display: flex; align-items: center; justify-content: space-between; gap: 40px; }

  @media (max-width: 860px) {
    .founding { grid-template-columns: 1fr; }
    .founding__stat { margin: 0 auto; }
    .milestone { grid-template-columns: 70px 1fr; gap: 20px; }
    .cta__inner { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 500px) {
    .milestone { grid-template-columns: 1fr; }
    .milestone__year-col { flex-direction: row; align-items: center; gap: 12px; }
    .milestone__line { display: none; }
  }
</style>
