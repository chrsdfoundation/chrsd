---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';

const upcoming = [
  {
    title: 'SDAMSMP National Stakeholder Roundtable',
    date: '15 July 2026',
    isoDate: '2026-07-15',
    time: '10:00–13:00 BST',
    venue: 'BRAC Centre Inn, Mohakhali, Dhaka',
    format: 'Policy roundtable (by invitation)',
    programme: 'Primary Education',
    description: 'Ministerial review of SDAMSMP pilot results from Dhaka District. Agenda includes presentation of 76.6% administrative reduction data, discussion of Phase 2 expansion to full Dhaka Division (10,925 schools), and policy pathway for national scale-up. Attendees: MoPME officials, DPE Director-General, CHRSD Executive Director, Nevronus Systems technical team.',
  },
  {
    title: 'BGMEA Vision Care Initiative: Consortium Alignment Meeting',
    date: '22 July 2026',
    isoDate: '2026-07-22',
    time: '14:00–17:00 BST',
    venue: 'BGMEA Complex, Uttara, Dhaka',
    format: 'Consortium meeting (industry + NGO + technology)',
    programme: 'Worker Health & ESG',
    description: 'Alignment session between CHRSD, BGMEA, Nevronus Systems, and Lunera to finalise the Phase 2 factory rollout schedule for the AI Vision Care Initiative. Agenda: Q1–Q2 2026 pilot data review, eyewear supply chain confirmation, ESG reporting framework for international buyers.',
  },
  {
    title: 'NSADMP Field Forester Training — Noakhali Division',
    date: '5–6 August 2026',
    isoDate: '2026-08-05',
    time: 'Full day (both days)',
    venue: 'Sonaimuri Upazila, Noakhali',
    format: 'Field training workshop',
    programme: 'Climate & Afforestation',
    description: 'Two-day practical training for 45 field foresters on the Nevronus mobile GIS application, NDVI threshold interpretation, species identification protocols, and documentation standards for the NSADMP verification framework.',
  },
  {
    title: 'GIS & Remote Sensing Technical Workshop — Nevronus Systems',
    date: '19 August 2026',
    isoDate: '2026-08-19',
    time: 'Full day',
    venue: 'ICT Tower, Agargaon, Dhaka + hybrid',
    format: 'Technical launch workshop',
    programme: 'Climate & Afforestation',
    description: 'Deep-dive technical session on NDVI monitoring pipeline integration, Sentinel-2 data access, and the Nevronus Systems dashboard. Open to CHRSD programme staff, partner NGOs, and Government of Bangladesh technical officers.',
  },
];

const past = [
  {
    title: 'MoEFCC Ministerial Programme Submission — NSADMP',
    date: 'February 2026',
    location: 'Ministry of Environment, Forest and Climate Change, Dhaka',
    programme: 'Climate & Afforestation',
    summary: 'CHRSD formally submitted the National Smart Afforestation & Digital Monitoring Programme to the Ministry of Environment, Forest and Climate Change. The submission included a 120-page programme document, budget justification (BDT 200 Crore), species suitability mapping, and the Nevronus Systems technology architecture. Receipt acknowledged.',
  },
  {
    title: 'MoPME/DPE Programme Submission — SDAMSMP',
    date: 'March 2026',
    location: 'Ministry of Primary and Mass Education, Dhaka',
    programme: 'Primary Education',
    summary: 'Formal submission of SDAMSMP to the Ministry of Primary and Mass Education and the Directorate of Primary Education. Submitted documents included pilot data from the Dhaka District cohort (951 schools, 7,740 teachers), hardware specifications, cost-benefit analysis, and national roll-out phasing plan.',
  },
  {
    title: 'Sonaimuri Tree Plantation Festival — World Environment Day 2026',
    date: '5 June 2026',
    location: 'Sonaimuri Upazila, Noakhali District',
    programme: 'Climate & Afforestation',
    summary: '5,000 native saplings planted by community volunteers, school students, women\'s cooperatives, and CHRSD field staff. 94.2% survival rate recorded at 30-day audit. Cited by UNEP Bangladesh as a model community-led reforestation initiative.',
  },
  {
    title: 'Dhaka Division School Orientation — SDAMSMP Phase 2 Groundwork',
    date: 'April–May 2026',
    location: '12 upazilas, Dhaka Division',
    programme: 'Primary Education',
    summary: 'Regional orientation programme for 340 school headmasters on the SDAMSMP digital attendance system. Covered hardware operation, data privacy protocols, grievance redressal, and system support channels.',
  },
];

const programmeColour: Record<string, string> = {
  'Primary Education': 'tag--blue',
  'Worker Health & ESG': 'tag--gold',
  'Climate & Afforestation': 'tag--green',
};
---
<BaseLayout
  title="Events"
  description="Upcoming and past events from CHRSD — stakeholder roundtables, field training workshops, and programme milestones."
>
  <PageHero
    overline="Stay informed · Events"
    title="Institutional agenda"
    lead="Stakeholder roundtables, field training workshops, and programme submission milestones — a transparent record of CHRSD's institutional activity."
  />

  <section class="section section--alt">
    <div class="container">
      <div class="section-intro">
        <p class="overline">Upcoming</p>
        <h2>Events & engagements</h2>
        <p class="section-lead">Scheduled activities across CHRSD programmes. To request attendance or observer status at invitation-only events, contact our programmes office.</p>
      </div>

      <div class="events-list">
        {upcoming.map((ev) => (
          <article class="event-card">
            <div class="event-card__aside">
              <time class="event-card__date" datetime={ev.isoDate}>
                {ev.date}
              </time>
              <span class="event-card__time">{ev.time}</span>
              <span class:list={['event-tag', programmeColour[ev.programme]]}>{ev.programme}</span>
            </div>
            <div class="event-card__body">
              <div class="event-card__format">{ev.format}</div>
              <h3 class="event-card__title">{ev.title}</h3>
              <div class="event-card__venue">
                <span class="venue-label">Venue</span>
                <span>{ev.venue}</span>
              </div>
              <p class="event-card__desc">{ev.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-intro">
        <p class="overline">Archive</p>
        <h2>Past events</h2>
        <p class="section-lead">A record of completed programme milestones, submissions, and field activities.</p>
      </div>

      <div class="past-list">
        {past.map((ev) => (
          <article class="past-card">
            <div class="past-card__rule" aria-hidden="true"></div>
            <div class="past-card__content">
              <div class="past-card__header">
                <div class="past-card__header-left">
                  <span class:list={['event-tag', programmeColour[ev.programme]]}>{ev.programme}</span>
                  <h3 class="past-card__title">{ev.title}</h3>
                </div>
                <div class="past-card__meta">
                  <span class="past-card__date">{ev.date}</span>
                  <span class="past-card__location">{ev.location}</span>
                </div>
              </div>
              <p class="past-card__summary">{ev.summary}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container contact-row">
      <div>
        <p class="overline">Stay connected</p>
        <h2>Event notifications</h2>
        <p style="margin-top:14px;font-size:15px;color:var(--color-slate);max-width:52ch;line-height:1.7">
          To receive advance notice of CHRSD events, roundtables, and programme milestones, contact our communications office or follow our updates page.
        </p>
      </div>
      <div class="contact-actions">
        <a href="/get-involved/contact-us/" class="cta-btn cta-btn--solid">Contact us</a>
        <a href="/stay-informed/news/" class="cta-btn cta-btn--outline">Latest news</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-intro { margin-bottom: 40px; }
  .section-intro h2 { margin-top: 12px; }
  .section-lead { font-size: 15px; color: var(--color-slate); margin-top: 12px; max-width: 60ch; line-height: 1.7; }

  .events-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .event-card {
    display: grid;
    grid-template-columns: 200px 1fr;
    background: #fff;
    border: 1px solid var(--color-border-green);
    border-radius: var(--radius);
    overflow: hidden;
    transition: box-shadow var(--dur) var(--ease);
  }

  .event-card:hover { box-shadow: var(--shadow-card-hover); }

  .event-card__aside {
    background: var(--color-forest);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .event-card__date {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    display: block;
  }

  .event-card__time {
    font-size: 13px;
    color: rgba(255,255,255,0.72);
    display: block;
  }

  .event-tag {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: var(--radius-pill);
    align-self: flex-start;
  }

  .tag--green { background: rgba(40,160,100,0.18); color: #28A064; border: 1px solid rgba(40,160,100,0.3); }
  .tag--blue { background: rgba(0,120,60,0.14); color: #00783C; border: 1px solid rgba(0,120,60,0.25); }
  .tag--gold { background: rgba(180,140,40,0.14); color: #8a6a10; border: 1px solid rgba(180,140,40,0.25); }

  .event-card__aside .tag--green,
  .event-card__aside .tag--blue,
  .event-card__aside .tag--gold {
    margin-top: auto;
  }

  .event-card__aside .event-tag {
    background: rgba(255,255,255,0.14);
    color: rgba(255,255,255,0.9);
    border-color: rgba(255,255,255,0.2);
  }

  .event-card__body {
    padding: 28px 32px;
  }

  .event-card__format {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 8px;
  }

  .event-card__title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--color-forest);
    line-height: 1.35;
    margin-bottom: 14px;
  }

  .event-card__venue {
    display: flex;
    gap: 10px;
    align-items: baseline;
    margin-bottom: 16px;
    font-size: 14px;
    color: var(--color-slate);
  }

  .venue-label {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-gold);
    flex-shrink: 0;
  }

  .event-card__desc {
    font-size: 15px;
    color: var(--color-ink);
    line-height: 1.7;
  }

  .past-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .past-card {
    display: flex;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid var(--color-border-green);
  }

  .past-card:first-child { padding-top: 0; }

  .past-card__rule {
    width: 3px;
    background: var(--color-border-green);
    border-radius: 2px;
    flex-shrink: 0;
    align-self: stretch;
  }

  .past-card__content { flex: 1; }

  .past-card__header {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    align-items: flex-start;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }

  .past-card__header-left {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .past-card__title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-forest);
    line-height: 1.35;
    margin: 0;
  }

  .past-card__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    flex-shrink: 0;
    text-align: right;
  }

  .past-card__date {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: var(--color-gold);
    white-space: nowrap;
  }

  .past-card__location {
    font-size: 12px;
    color: var(--color-slate);
    white-space: nowrap;
    max-width: 200px;
    text-align: right;
    line-height: 1.4;
  }

  .past-card__summary {
    font-size: 15px;
    color: var(--color-slate);
    line-height: 1.7;
  }

  .contact-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    align-items: center;
  }

  .contact-row h2 { margin-top: 12px; }

  .contact-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-shrink: 0;
  }

  .cta-btn {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    padding: 12px 28px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    text-align: center;
    transition: background var(--dur) var(--ease), box-shadow var(--dur) var(--ease), color var(--dur) var(--ease);
  }

  .cta-btn--solid {
    background: var(--color-institutional);
    color: #fff;
  }

  .cta-btn--solid:hover {
    background: var(--color-forest);
    box-shadow: 0 4px 16px rgba(0,120,60,0.25);
  }

  .cta-btn--outline {
    background: transparent;
    color: var(--color-institutional);
    border: 1.5px solid var(--color-institutional);
  }

  .cta-btn--outline:hover { background: var(--color-tint); }

  @media (max-width: 900px) {
    .event-card { grid-template-columns: 1fr; }
    .event-card__aside {
      flex-direction: row;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
      padding: 18px 22px;
    }
    .event-card__aside .event-tag { margin-top: 0; }
    .contact-row { grid-template-columns: 1fr; }
    .contact-actions { flex-direction: row; }
    .past-card__header { flex-direction: column; }
    .past-card__meta { align-items: flex-start; text-align: left; }
    .past-card__location { text-align: left; }
  }

  @media (max-width: 600px) {
    .contact-actions { flex-direction: column; }
    .past-card { gap: 14px; }
  }
</style>
