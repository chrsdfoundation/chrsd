---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import Button from '@components/Button.astro';

const reports = [
  {
    year: '2024–25',
    title: 'Annual Progress Report FY 2024–25',
    subtitle: 'Reaching scale without losing depth',
    highlights: ['8 crore trees planted & verified', 'SDAMSMP scales to 12,000 schools', '340 legal aid cases concluded', '3 peer-reviewed papers published'],
    pages: 84,
    size: '6.2 MB',
    cover: '',
    latest: true,
  },
  {
    year: '2023–24',
    title: 'Annual Progress Report FY 2023–24',
    subtitle: 'Digital verification at scale',
    highlights: ['NSADMP Phase I milestone: 5 crore trees', 'SDAMSMP pilot expanded to 5,000 schools', 'Anti-trafficking reach: 28,000 households', 'First GIS open dataset released'],
    pages: 78,
    size: '5.7 MB',
    cover: '',
    latest: false,
  },
  {
    year: '2022–23',
    title: 'Annual Progress Report FY 2022–23',
    subtitle: 'Building the evidence engine',
    highlights: ['NSADMP formally launched', 'SDAMSMP 500-school pilot begins', 'Labour market research series initiated', '14-district field presence established'],
    pages: 71,
    size: '5.1 MB',
    cover: '',
    latest: false,
  },
  {
    year: '2021–22',
    title: 'Annual Progress Report FY 2021–22',
    subtitle: 'Recovering, adapting, growing',
    highlights: ['Post-pandemic community welfare pivot', 'Climate resilience fund activated', 'Human rights monitoring expanded', '200+ volunteers mobilised'],
    pages: 65,
    size: '4.4 MB',
    cover: '',
    latest: false,
  },
  {
    year: '2020–21',
    title: 'Annual Progress Report FY 2020–21',
    subtitle: 'Responding to compound crises',
    highlights: ['COVID-19 community response programme', 'Cyclone Amphan recovery operations', 'Legal aid helpline launched', 'Digital infrastructure investment begins'],
    pages: 60,
    size: '4.0 MB',
    cover: '',
    latest: false,
  },
];
---
<BaseLayout
  title="Annual Progress Reports"
  description="CHRSD's annual progress reports — a transparent, independently verified account of our programmes and impact."
>
  <PageHero
    overline="Impact & evidence · Publications"
    title="Annual Progress Reports"
    lead="Every year we publish a full account of our programmes, financials, and impact — written for the communities we serve, the partners who support us, and anyone who wants to hold us accountable."
  />

  <!-- REPORTING APPROACH -->
  <section class="section section--alt">
    <div class="container approach">
      <div>
        <p class="overline">How we report</p>
        <h2>Open, verified, accessible</h2>
        <p class="lead" style="margin-top:14px">
          CHRSD's annual reports cover programme delivery, financial performance, external
          audit findings, and independent evaluation outcomes. All data is independently
          verified before publication.
        </p>
      </div>
      <div class="approach-points">
        {[
          { title: 'Independently audited', body: 'Financial data in each report is drawn from independently audited accounts.' },
          { title: 'Evaluator-reviewed', body: 'Impact data is validated by our external evaluation partners before publication.' },
          { title: 'Open access', body: 'All reports are published in full — no gated access, no summary-only versions.' },
          { title: 'Plain language', body: 'Written for a general audience, not just specialists or institutional donors.' },
        ].map((p) => (
          <article class="apoint">
            <span class="apoint__rule" aria-hidden="true"></span>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- REPORT LISTING -->
  <section class="section">
    <div class="container">
      <p class="overline">Published reports</p>
      <h2>Five years of open reporting</h2>
      <div class="reports">
        {reports.map((r) => (
          <article class:list={['report', { 'report--latest': r.latest }]}>
            {r.latest && <span class="report__badge">Latest report</span>}
            <div class="report__cover" aria-hidden="true">
              <span class="report__year-bg">{r.year}</span>
            </div>
            <div class="report__body">
              <span class="report__year-label">{r.year}</span>
              <h3 class="report__title">{r.title}</h3>
              <p class="report__subtitle">{r.subtitle}</p>
              <ul class="report__highlights">
                {r.highlights.map((h: string) => <li>{h}</li>)}
              </ul>
              <div class="report__meta">
                <span>{r.pages} pages</span>
                <span>PDF · {r.size}</span>
              </div>
              <div class="report__actions">
                <a
                  href={`/reports/annual-report-${r.year.replace('–', '-')}.pdf`}
                  class="btn btn--solid btn--md"
                  aria-label={`Download ${r.title} (PDF, ${r.size})`}
                >
                  Download PDF
                </a>
                <a
                  href={`/reports/annual-report-${r.year.replace('–', '-')}-accessible.pdf`}
                  class="report__alt-link"
                  aria-label={`Download accessible version of ${r.title}`}
                >
                  Accessible version
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="older">
        <p>
          Reports older than FY 2020–21 are available on request.
          <a href="/get-involved/contact-us/">Contact us</a> or email
          <a href="mailto:info@chrsd.org">info@chrsd.org</a> with the subject line
          "Annual report request".
        </p>
      </div>
    </div>
  </section>

  <!-- OTHER PUBLICATIONS -->
  <section class="section section--alt">
    <div class="container pub-links">
      <p class="overline">Related resources</p>
      <h2>Other publications</h2>
      <div class="pub-grid">
        <a href="/about-us/governance-and-good-practices/financials-and-external-audit/" class="pub-card">
          <span class="pub-card__icon" aria-hidden="true">📋</span>
          <h3>Financial Audits</h3>
          <p>Independently audited accounts, signed off by registered Chartered Accountants.</p>
          <span class="pub-card__link">View financial audits →</span>
        </a>
        <a href="/impact/research-papers/" class="pub-card">
          <span class="pub-card__icon" aria-hidden="true">🔬</span>
          <h3>Research Papers</h3>
          <p>Peer-reviewed studies on labour markets, climate change, and community development.</p>
          <span class="pub-card__link">View research papers →</span>
        </a>
        <a href="/impact/policy-briefings/" class="pub-card">
          <span class="pub-card__icon" aria-hidden="true">📄</span>
          <h3>Policy Briefings</h3>
          <p>Concise policy notes translating our research evidence for decision-makers.</p>
          <span class="pub-card__link">View policy briefings →</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Approach */
  .approach { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
  .approach h2 { margin-top: 12px; }
  .approach-points { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .apoint { background: #fff; border: 1px solid var(--color-border-green); border-radius: var(--radius); padding: 22px 24px; }
  .apoint__rule { display: block; width: 36px; height: 3px; background: var(--color-gold); border-radius: 2px; margin-bottom: 14px; }
  .apoint h3 { font-size: 16px; color: var(--color-forest); margin-bottom: 8px; }
  .apoint p { font-size: 14px; color: var(--color-slate); line-height: 1.65; }

  /* Reports */
  .reports { display: flex; flex-direction: column; gap: 20px; margin-top: 40px; }
  .report {
    display: grid; grid-template-columns: 160px 1fr; gap: 0;
    background: #fff; border: 1px solid var(--color-border-green);
    border-radius: var(--radius); overflow: hidden;
    transition: box-shadow var(--dur) var(--ease);
    position: relative;
  }
  .report:hover { box-shadow: var(--shadow-card-hover); }
  .report--latest { border-color: var(--color-institutional); border-width: 2px; }
  .report__badge {
    position: absolute; top: 16px; right: 16px;
    background: var(--color-institutional); color: #fff;
    font-family: var(--font-display); font-weight: 600; font-size: 12px;
    padding: 5px 12px; border-radius: var(--radius-pill);
  }
  .report__cover {
    background: var(--color-forest); display: flex; align-items: center; justify-content: center;
    padding: 20px;
  }
  .report__year-bg {
    font-family: var(--font-display); font-weight: 800; font-size: 22px;
    color: rgba(255,255,255,0.4); text-align: center; line-height: 1.3; letter-spacing: -0.02em;
  }
  .report__body { padding: 26px 30px; }
  .report__year-label { font-family: var(--font-display); font-weight: 700; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-gold); }
  .report__title { font-size: 20px; color: var(--color-forest); margin: 8px 0 4px; }
  .report__subtitle { font-size: 15px; color: var(--color-slate); font-style: italic; margin-bottom: 14px; }
  .report__highlights { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
  .report__highlights li { font-size: 13px; color: var(--color-institutional); background: var(--color-tint); border: 1px solid var(--color-border-green); padding: 4px 10px; border-radius: var(--radius-pill); font-weight: 600; }
  .report__meta { display: flex; gap: 16px; font-size: 13px; color: var(--color-slate); margin-bottom: 18px; }
  .report__actions { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .report__alt-link { font-size: 14px; color: var(--color-institutional); text-decoration: none; }
  .report__alt-link:hover { text-decoration: underline; }

  .older { margin-top: 24px; padding: 16px 20px; background: var(--color-tint); border: 1px solid var(--color-border-green); border-radius: var(--radius); font-size: 14px; color: var(--color-slate); }
  .older a { color: var(--color-institutional); }

  /* Other publications */
  .pub-links h2 { margin-top: 12px; }
  .pub-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 32px; }
  .pub-card {
    display: block; background: #fff; border: 1px solid var(--color-border-green);
    border-radius: var(--radius); padding: 26px; text-decoration: none;
    transition: box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .pub-card:hover { box-shadow: var(--shadow-card-hover); transform: translateY(-3px); }
  .pub-card__icon { display: block; font-size: 26px; margin-bottom: 14px; }
  .pub-card h3 { font-size: 18px; color: var(--color-forest); margin-bottom: 10px; }
  .pub-card p { font-size: 14px; color: var(--color-slate); line-height: 1.65; margin-bottom: 16px; }
  .pub-card__link { font-size: 14px; font-weight: 600; color: var(--color-institutional); }

  @media (max-width: 1024px) {
    .approach { grid-template-columns: 1fr; }
    .pub-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 700px) {
    .report { grid-template-columns: 1fr; }
    .report__cover { height: 80px; }
    .pub-grid { grid-template-columns: 1fr; }
    .approach-points { grid-template-columns: 1fr; }
  }
</style>
