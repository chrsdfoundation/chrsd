---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';

const counters = [
  {
    id: 'trees',
    value: 250000000,
    display: '250,000,000',
    label: 'Trees Targeted for Afforestation',
    sublabel: 'Phase 1: 20,000,000 trees',
    suffix: '',
    unit: 'NSADMP National Target',
  },
  {
    id: 'teachers',
    value: 379624,
    display: '379,624',
    label: 'Teachers in Digital Framework',
    sublabel: 'Across 65,566+ government primary schools',
    suffix: '',
    unit: 'SDAMSMP National Scale',
  },
  {
    id: 'schools',
    value: 65566,
    display: '65,566',
    label: 'Primary Schools Covered',
    sublabel: 'Full national coverage target',
    suffix: '',
    unit: 'Government Primary Schools',
  },
  {
    id: 'survival',
    value: null,
    display: '85–90%',
    label: 'Verified Tree Survival Rate',
    sublabel: 'vs. 40–55% national unverified baseline',
    suffix: '%',
    unit: 'NSADMP Survival Benchmark',
    isRange: true,
  },
  {
    id: 'admin',
    value: 30,
    display: '30%',
    label: 'Admin Overhead Reduction',
    sublabel: 'SDAMSMP field pilot data',
    suffix: '%',
    unit: 'Headmaster workload reduction',
  },
  {
    id: 'workers',
    value: 1200000,
    display: '1,200,000',
    label: 'RMG Workers Targeted',
    sublabel: 'BGMEA sector, partnered with Nevronus & Lunera',
    suffix: '',
    unit: 'Vision Care Initiative',
  },
];

const tableRows = [
  {
    name: 'NSADMP',
    fullName: 'National Smart Afforestation & Digital Monitoring Programme',
    status: 'Submitted — Under Review',
    budget: 'BDT 200 Crore',
    partner: 'MoEFCC, Government of Bangladesh',
    beneficiaries: '250 million trees / National population',
  },
  {
    name: 'SDAMSMP',
    fullName: 'Smart Digital Attendance Management System & Monitoring Programme',
    status: 'Submitted — Under Review',
    budget: 'BDT 41.98 Crore',
    partner: 'MoPME / Directorate of Primary Education',
    beneficiaries: '379,624 teachers · 65,566+ schools',
  },
  {
    name: 'Vision Care Initiative',
    fullName: 'AI Vision Care Initiative',
    status: 'Partnership Active',
    budget: '~$10–12 per worker',
    partner: 'BGMEA · Nevronus Systems · Lunera',
    beneficiaries: '1.2 million RMG garment workers',
  },
];
---
<BaseLayout
  title="Live Impact Counters"
  description="CHRSD's programme impact dashboard — verified metrics across afforestation, digital education governance, and worker vision care as of Q2 2026."
>
  <PageHero
    overline="Impact & evidence · Data engine"
    title="Programme impact, counted and verified"
    lead="Every number on this page reflects a submitted programme proposal, a signed partnership, or a field-verified result. These are not aspirational targets — they are the measurable commitments CHRSD has made and is being held to."
  />

  <div class="metadata-bar">
    <div class="container">
      <div class="metadata-bar__inner">
        <span class="meta-chip">As of Q2 2026</span>
        <span class="meta-sep" aria-hidden="true"></span>
        <span class="meta-item">National Dashboard Data Reviewed Quarterly</span>
        <span class="meta-sep" aria-hidden="true"></span>
        <span class="meta-item">Source: CHRSD Programme Management Unit</span>
      </div>
    </div>
  </div>

  <section class="section section--alt">
    <div class="container">
      <p class="overline">Programme metrics</p>
      <h2>National-scale numbers</h2>

      <div class="counters-grid">
        {counters.map((c) => (
          <article
            class="counter-card"
            data-counter={c.isRange ? undefined : String(c.value)}
            data-suffix={c.suffix}
            data-display={c.display}
          >
            <span class="counter-card__unit">{c.unit}</span>
            <span
              class="counter-card__number"
              data-target={c.isRange ? undefined : String(c.value)}
              data-display={c.display}
            >
              {c.display}
            </span>
            <h3 class="counter-card__label">{c.label}</h3>
            <p class="counter-card__sublabel">{c.sublabel}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="overline">Programme breakdown</p>
      <h2>Three programmes, one accountability framework</h2>
      <p class="table-lead">
        The table below summarises the status, budget, institutional partner, and target beneficiary
        count for each of CHRSD's three active national programmes as of Q2 2026.
      </p>

      <div class="table-wrapper" role="region" aria-label="Programme summary table" tabindex="0">
        <table class="prog-table">
          <thead>
            <tr>
              <th scope="col">Programme</th>
              <th scope="col">Status</th>
              <th scope="col">Budget</th>
              <th scope="col">Ministry / Partner</th>
              <th scope="col">Target Beneficiaries</th>
            </tr>
          </thead>
          <tbody>
            {tableRows.map((row) => (
              <tr>
                <td>
                  <strong class="prog-name">{row.name}</strong>
                  <span class="prog-fullname">{row.fullName}</span>
                </td>
                <td>
                  <span class:list={['status-badge', row.status === 'Partnership Active' ? 'status-badge--active' : 'status-badge--review']}>
                    {row.status}
                  </span>
                </td>
                <td class="budget-cell">{row.budget}</td>
                <td>{row.partner}</td>
                <td>{row.beneficiaries}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container evidence">
      <div>
        <p class="overline">Evidence base</p>
        <h2>The studies behind the numbers</h2>
        <p class="evidence__lead">
          CHRSD's programme design is grounded in published research. The productivity and income
          figures cited in the Vision Care Initiative draw from three independent studies conducted
          across multiple countries and sectors.
        </p>
      </div>
      <div class="evidence-cards">
        <article class="evidence-card">
          <span class="evidence-card__rule"></span>
          <h3>PROSPER II Study</h3>
          <p class="evidence-card__finding">6% productivity gain · 3× ROI in 3 months</p>
          <p>Multi-country study on the economic return of corrective eyewear in production environments.</p>
        </article>
        <article class="evidence-card">
          <span class="evidence-card__rule"></span>
          <h3>VisionSpring Research</h3>
          <p class="evidence-card__finding">22–32% productivity uplift</p>
          <p>Sector-wide analysis of vision correction impact in manufacturing and assembly workforces.</p>
        </article>
        <article class="evidence-card">
          <span class="evidence-card__rule"></span>
          <h3>THRIVE Study — Bangladesh</h3>
          <p class="evidence-card__finding">33.4% income gain post-correction</p>
          <p>Bangladesh-specific study measuring income change among garment workers following vision correction.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .metadata-bar {
    background: var(--color-forest); border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .metadata-bar__inner {
    display: flex; align-items: center; flex-wrap: wrap; gap: 14px;
    padding-block: 14px;
  }
  .meta-chip {
    font-family: var(--font-display); font-weight: 700; font-size: 12px;
    background: var(--color-gold); color: var(--color-forest);
    padding: 4px 12px; border-radius: var(--radius-pill);
    text-transform: uppercase; letter-spacing: 0.06em;
  }
  .meta-sep {
    width: 1px; height: 16px; background: rgba(255,255,255,0.25); flex-shrink: 0;
  }
  .meta-item {
    font-size: 13px; color: rgba(255,255,255,0.75); font-weight: 500;
  }

  .counters-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px;
  }
  .counter-card {
    background: #fff; border: 1px solid var(--color-border-green);
    border-radius: var(--radius); padding: 30px 28px;
    display: flex; flex-direction: column; gap: 0;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .counter-card:hover { box-shadow: 0 8px 28px rgba(20,60,20,0.1); transform: translateY(-2px); }
  .counter-card__unit {
    font-family: var(--font-display); font-weight: 700; font-size: 10px;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-gold);
    margin-bottom: 10px; display: block;
  }
  .counter-card__number {
    font-family: var(--font-display); font-weight: 800;
    font-size: clamp(32px, 3.5vw, 48px); color: var(--color-forest);
    line-height: 1; letter-spacing: -0.03em;
    display: block; margin-bottom: 14px;
  }
  .counter-card__label {
    font-size: 16px; font-weight: 700; color: var(--color-forest);
    margin: 0 0 8px; line-height: 1.3;
  }
  .counter-card__sublabel {
    font-size: 13px; color: var(--color-slate); line-height: 1.55; margin: 0;
  }

  .table-lead {
    font-size: 15px; color: var(--color-slate); max-width: 70ch;
    line-height: 1.7; margin-top: 14px; margin-bottom: 32px;
  }
  .table-wrapper {
    overflow-x: auto; border: 1px solid var(--color-border-green);
    border-radius: var(--radius);
  }
  .prog-table {
    width: 100%; border-collapse: collapse;
    font-size: 14px; min-width: 700px;
  }
  .prog-table thead { background: var(--color-forest); }
  .prog-table thead th {
    padding: 14px 18px; text-align: left;
    font-family: var(--font-display); font-weight: 600; font-size: 12px;
    letter-spacing: 0.07em; text-transform: uppercase; color: rgba(255,255,255,0.85);
    white-space: nowrap;
  }
  .prog-table tbody tr {
    border-bottom: 1px solid var(--color-border-green);
    transition: background 0.15s;
  }
  .prog-table tbody tr:last-child { border-bottom: none; }
  .prog-table tbody tr:hover { background: var(--color-tint); }
  .prog-table td { padding: 16px 18px; color: var(--color-forest); vertical-align: top; }

  .prog-name { display: block; font-weight: 700; color: var(--color-forest); margin-bottom: 4px; }
  .prog-fullname { display: block; font-size: 12px; color: var(--color-slate); line-height: 1.4; }

  .status-badge {
    display: inline-block; font-size: 11px; font-weight: 600;
    padding: 4px 10px; border-radius: var(--radius-pill); white-space: nowrap;
  }
  .status-badge--review {
    background: rgba(180, 140, 40, 0.12); color: #7a5c0e;
    border: 1px solid rgba(180, 140, 40, 0.3);
  }
  .status-badge--active {
    background: rgba(0, 120, 60, 0.1); color: var(--color-institutional);
    border: 1px solid rgba(0, 120, 60, 0.25);
  }
  .budget-cell { font-family: var(--font-display); font-weight: 700; }

  .evidence { display: grid; grid-template-columns: 340px 1fr; gap: 60px; align-items: start; }
  .evidence__lead {
    font-size: 15px; color: var(--color-slate); line-height: 1.75;
    margin-top: 14px;
  }
  .evidence-cards { display: flex; flex-direction: column; gap: 16px; }
  .evidence-card {
    background: #fff; border: 1px solid var(--color-border-green);
    border-radius: var(--radius); padding: 24px 26px;
  }
  .evidence-card__rule {
    display: block; width: 36px; height: 3px;
    background: var(--color-gold); border-radius: 2px; margin-bottom: 14px;
  }
  .evidence-card h3 { font-size: 16px; color: var(--color-forest); margin-bottom: 6px; }
  .evidence-card__finding {
    font-family: var(--font-display); font-weight: 700; font-size: 17px;
    color: var(--color-institutional); margin-bottom: 10px;
  }
  .evidence-card p:last-child { font-size: 14px; color: var(--color-slate); line-height: 1.65; margin: 0; }

  @media (max-width: 1024px) {
    .counters-grid { grid-template-columns: repeat(2, 1fr); }
    .evidence { grid-template-columns: 1fr; gap: 32px; }
  }
  @media (max-width: 640px) {
    .counters-grid { grid-template-columns: 1fr; }
    .metadata-bar__inner { gap: 10px; }
    .meta-sep { display: none; }
  }
</style>

<script>
  function formatNumber(n: number): string {
    return n.toLocaleString('en-US');
  }

  function animateCounter(el: Element): void {
    const target = parseInt(el.getAttribute('data-target') ?? '0', 10);
    const displayAttr = el.getAttribute('data-display') ?? '';

    if (!target || isNaN(target)) return;

    const duration = 1800;
    const start = performance.now();

    function tick(now: number): void {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(eased * target);

      if (displayAttr.includes('%')) {
        el.textContent = formatNumber(current) + '%';
      } else {
        el.textContent = formatNumber(current);
      }

      if (progress < 1) {
        requestAnimationFrame(tick);
      } else {
        el.textContent = displayAttr;
      }
    }

    requestAnimationFrame(tick);
  }

  const numberEls = document.querySelectorAll<Element>('.counter-card__number[data-target]');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          animateCounter(entry.target);
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );

  numberEls.forEach((el) => observer.observe(el));
</script>
