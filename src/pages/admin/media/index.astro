---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import MediaUploader from "../../../components/admin/MediaUploader";
---

<BaseLayout title="Media — CHRSD Admin" description="Manage media assets">
  <div style="min-height:100vh;background:#f9fafb;">
    <nav style="background:#1a4a6e;padding:0 24px;display:flex;align-items:center;gap:16px;height:56px;">
      <a href="/admin" style="color:white;text-decoration:none;font-weight:700;">CHRSD Admin</a>
      <span style="color:rgba(255,255,255,0.5);">/</span>
      <span style="color:rgba(255,255,255,0.85);font-size:0.875rem;">Media</span>
      <div style="flex:1;" />
      <form method="POST" action="/api/auth/logout">
        <button type="submit" style="background:rgba(255,255,255,0.15);border:none;color:white;padding:6px 14px;border-radius:5px;cursor:pointer;font-size:0.8125rem;">Sign Out</button>
      </form>
    </nav>

    <main style="padding:32px 24px;max-width:900px;margin:0 auto;">
      <h1 style="font-size:1.5rem;font-weight:700;color:#1e293b;margin-bottom:24px;">Media Library</h1>

      <div style="background:white;border:1px solid #e5e7eb;border-radius:10px;padding:32px;margin-bottom:24px;">
        <h2 style="font-size:1rem;font-weight:600;color:#1e293b;margin-bottom:16px;">Upload File</h2>
        <MediaUploader client:load />
      </div>

      <div style="background:white;border:1px solid #e5e7eb;border-radius:10px;padding:32px;text-align:center;color:#9ca3af;">
        Media library grid coming soon.
      </div>
    </main>
  </div>
</BaseLayout>
