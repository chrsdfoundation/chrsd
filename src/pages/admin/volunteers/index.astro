---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Volunteers — CHRSD Admin" description="Manage volunteers">
  <div style="min-height:100vh;background:#f9fafb;">
    <nav style="background:#1a4a6e;padding:0 24px;display:flex;align-items:center;gap:16px;height:56px;">
      <a href="/admin" style="color:white;text-decoration:none;font-weight:700;">CHRSD Admin</a>
      <span style="color:rgba(255,255,255,0.5);">/</span>
      <span style="color:rgba(255,255,255,0.85);font-size:0.875rem;">Volunteers</span>
      <div style="flex:1;" />
      <form method="POST" action="/api/auth/logout">
        <button type="submit" style="background:rgba(255,255,255,0.15);border:none;color:white;padding:6px 14px;border-radius:5px;cursor:pointer;font-size:0.8125rem;">Sign Out</button>
      </form>
    </nav>

    <main style="padding:32px 24px;max-width:1100px;margin:0 auto;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
        <h1 style="font-size:1.5rem;font-weight:700;color:#1e293b;">Volunteers</h1>
        <a href="/admin/volunteers/new" style="background:#1a4a6e;color:white;padding:8px 18px;border-radius:6px;text-decoration:none;font-size:0.875rem;font-weight:600;">+ Add Volunteer</a>
      </div>

      <div id="volunteer-list" style="background:white;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;">
        <div style="padding:32px;text-align:center;color:#9ca3af;">Loading volunteers…</div>
      </div>
    </main>
  </div>
</BaseLayout>

<script>
  async function loadVolunteers() {
    const res = await fetch('/api/volunteers');
    const el = document.getElementById('volunteer-list')!;
    if (!res.ok) {
      el.innerHTML = '<div style="padding:32px;text-align:center;color:#dc2626;">Failed to load volunteers.</div>';
      return;
    }
    const items = await res.json();

    if (items.length === 0) {
      el.innerHTML = '<div style="padding:32px;text-align:center;color:#9ca3af;">No volunteers yet.</div>';
      return;
    }

    el.innerHTML = (items as any[]).map(v => `
      <div style="display:flex;align-items:center;padding:14px 20px;border-bottom:1px solid #f3f4f6;">
        <div style="flex:1;">
          <div style="font-weight:600;font-size:0.9375rem;color:#1e293b;">${v.fullName}</div>
          <div style="font-size:0.8125rem;color:#6b7280;">${v.email ?? ''} ${v.district ? '· ' + v.district : ''}</div>
        </div>
        <span style="font-size:0.75rem;padding:3px 10px;border-radius:12px;background:${v.isActive ? '#dcfce7' : '#f3f4f6'};color:${v.isActive ? '#16a34a' : '#6b7280'};">${v.isActive ? 'Active' : 'Inactive'}</span>
        <a href="/admin/volunteers/${v.id}" style="margin-left:12px;color:#1a4a6e;font-size:0.8125rem;text-decoration:none;">View →</a>
      </div>
    `).join('');
  }

  loadVolunteers();
</script>
