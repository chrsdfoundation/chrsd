---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CertificateForm from "../../../components/admin/CertificateForm";
---

<BaseLayout title="Generate Certificate — CHRSD Admin" description="Generate volunteer certificates">
  <div style="min-height:100vh;background:#f9fafb;">
    <nav style="background:#1a4a6e;padding:0 24px;display:flex;align-items:center;gap:16px;height:56px;">
      <a href="/admin" style="color:white;text-decoration:none;font-weight:700;">CHRSD Admin</a>
      <span style="color:rgba(255,255,255,0.5);">/</span>
      <span style="color:rgba(255,255,255,0.85);font-size:0.875rem;">Certificates</span>
      <div style="flex:1;" />
      <form method="POST" action="/api/auth/logout">
        <button type="submit" style="background:rgba(255,255,255,0.15);border:none;color:white;padding:6px 14px;border-radius:5px;cursor:pointer;font-size:0.8125rem;">Sign Out</button>
      </form>
    </nav>

    <main style="padding:32px 24px;max-width:700px;margin:0 auto;">
      <h1 style="font-size:1.5rem;font-weight:700;color:#1e293b;margin-bottom:8px;">Generate Certificate</h1>
      <p style="color:#6b7280;margin-bottom:32px;">Issue a volunteer certificate. The PDF will be stored securely and a time-limited download link generated.</p>
      <div style="background:white;border:1px solid #e5e7eb;border-radius:10px;padding:32px;">
        <CertificateForm client:load />
      </div>
    </main>
  </div>
</BaseLayout>
