---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import { site } from '@data/navigation';

const governance = [
  { title: 'CHRSD Procurement Policy v1.0', type: 'Policy', programme: 'All programmes', format: 'PDF' },
  { title: 'CHRSD Supplier Code of Conduct v1.0', type: 'Policy', programme: 'All programmes', format: 'PDF' },
  { title: 'Whistleblower Protection Policy v1.0', type: 'Policy', programme: 'Institutional', format: 'PDF' },
  { title: 'Anti-Corruption & Anti-Bribery Policy v1.0', type: 'Policy', programme: 'Institutional', format: 'PDF' },
  { title: 'Data Privacy & Security Policy v1.0', type: 'Policy', programme: 'All programmes', format: 'PDF' },
  { title: 'Child & Vulnerable Adult Safeguarding Policy v1.0', type: 'Policy', programme: 'All programmes', format: 'PDF' },
  { title: 'Registrations & Compliance Certificate Bundle', type: 'Legal', programme: 'Institutional', format: 'PDF' },
];

const nsadmp = [
  { title: 'NSADMP Programme Document — Full MoEFCC Submission, 120 pp', type: 'Programme Document', programme: 'NSADMP', format: 'PDF' },
  { title: 'NSADMP Species Suitability Mapping Report', type: 'Research', programme: 'NSADMP', format: 'PDF' },
  { title: 'NSADMP Technology Architecture Overview (Nevronus Systems)', type: 'Technical Guide', programme: 'NSADMP', format: 'PDF' },
  { title: 'NSADMP Pilot Audit Report: Sonaimuri, June 2026', type: 'Programme Document', programme: 'NSADMP', format: 'PDF' },
  { title: 'NSADMP Annual Procurement Plan 2026–2027', type: 'Programme Document', programme: 'NSADMP', format: 'PDF' },
  { title: 'GIS Field Forester Mobile App User Guide (Bangla Edition)', type: 'Training Material', programme: 'NSADMP', format: 'PDF' },
  { title: 'NDVI Monitoring Protocol v2.1', type: 'Technical Guide', programme: 'NSADMP', format: 'PDF' },
];

const sdamsmp = [
  { title: 'SDAMSMP Programme Document — Full MoPME/DPE Submission, 85 pp', type: 'Programme Document', programme: 'SDAMSMP', format: 'PDF' },
  { title: 'SDAMSMP Pilot Results Report: Dhaka District, Q4 2025–Q1 2026', type: 'Programme Document', programme: 'SDAMSMP', format: 'PDF' },
  { title: 'Nevronus Biometric Attendance System — Technical Specification', type: 'Technical Guide', programme: 'SDAMSMP', format: 'PDF' },
  { title: 'SDAMSMP Data Privacy Impact Assessment', type: 'Policy', programme: 'SDAMSMP', format: 'PDF' },
  { title: 'Headmaster Orientation Manual (Bangla Edition)', type: 'Training Material', programme: 'SDAMSMP', format: 'PDF' },
  { title: 'SDAMSMP Annual Budget Breakdown: BDT 41.98 Crore', type: 'Programme Document', programme: 'SDAMSMP', format: 'PDF' },
];

const vision = [
  { title: 'Vision Care Initiative — Concept Note and BGMEA Partnership Framework', type: 'Programme Document', programme: 'Vision Care', format: 'PDF' },
  { title: 'Pilot Clinical Data Summary: RMG Factory Screening, Q1 2026', type: 'Research', programme: 'Vision Care', format: 'PDF' },
  { title: 'AI Diagnostic Pipeline Technical Overview (Nevronus + Lunera)', type: 'Technical Guide', programme: 'Vision Care', format: 'PDF' },
  { title: 'Evidence Review: PROSPER II, VisionSpring, THRIVE — Synthesis Document', type: 'Research', programme: 'Vision Care', format: 'PDF' },
];

const publications = [
  { title: '5 published research papers', type: 'Research', programme: 'Institutional', format: 'Link', href: '/impact/research-papers/' },
  { title: '3 policy briefings', type: 'Policy', programme: 'Institutional', format: 'Link', href: '/impact/policy-briefings/' },
  { title: 'Annual Progress Reports', type: 'Programme Document', programme: 'Institutional', format: 'Link', href: '/impact/annual-reports/' },
];

function typeClass(type: string) {
  if (type === 'Policy') return 'badge--policy';
  if (type === 'Research') return 'badge--research';
  if (type === 'Technical Guide') return 'badge--tech';
  if (type === 'Training Material') return 'badge--training';
  if (type === 'Legal') return 'badge--legal';
  return 'badge--doc';
}

function progClass(prog: string) {
  if (prog === 'NSADMP') return 'prog--nsadmp';
  if (prog === 'SDAMSMP') return 'prog--sdamsmp';
  if (prog === 'Vision Care') return 'prog--vision';
  return 'prog--inst';
}
---
<BaseLayout
  title="Resource Library"
  description="The CHRSD Resource Library consolidates all organisational knowledge assets — programme documents, policy frameworks, technical guides, research publications, and legal compliance materials."
>
  <PageHero
    overline="Resources · Knowledge Base"
    title="Resource Library"
    lead="The CHRSD Resource Library consolidates all organisational knowledge assets — programme documents, policy frameworks, technical guides, research publications, and legal compliance materials — in one searchable catalogue."
  />

  <section class="section section--alt">
    <div class="container">
      <div class="search-bar">
        <div class="search-input-wrap">
          <svg class="search-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="7.5" cy="7.5" r="5.5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 12l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <input type="search" class="search-input" placeholder="Search resources…" aria-label="Search resources" />
        </div>
        <select class="filter-select" aria-label="Filter by document type">
          <option value="">Document Type: All</option>
          <option>Policy</option>
          <option>Programme Document</option>
          <option>Research</option>
          <option>Technical Guide</option>
          <option>Training Material</option>
          <option>Legal</option>
        </select>
        <select class="filter-select" aria-label="Filter by programme area">
          <option value="">Programme Area: All</option>
          <option>NSADMP</option>
          <option>SDAMSMP</option>
          <option>Vision Care</option>
          <option>Institutional</option>
        </select>
      </div>
      <p class="access-note">Documents are available to programme partners and institutional stakeholders. <a href="/get-involved/contact-us/">Contact CHRSD</a> to request access to restricted materials.</p>
    </div>
  </section>

  <section class="section">
    <div class="container catalogue">
      <details class="cat-section" open>
        <summary class="cat-summary">
          <span class="cat-title">Institutional Governance</span>
          <span class="cat-count">7 assets</span>
          <svg class="cat-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <ul class="asset-list">
          {governance.map((item) => (
            <li class="asset-row">
              <span class="asset-title">{item.title}</span>
              <div class="asset-badges">
                <span class:list={['asset-badge', typeClass(item.type)]}>{item.type}</span>
                <span class:list={['asset-prog', progClass(item.programme)]}>{item.programme}</span>
                <span class="asset-format">{item.format}</span>
              </div>
              <a href="#" class="asset-btn">Request access</a>
            </li>
          ))}
        </ul>
      </details>

      <details class="cat-section">
        <summary class="cat-summary">
          <span class="cat-title">NSADMP</span>
          <span class="cat-count">7 assets</span>
          <svg class="cat-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <ul class="asset-list">
          {nsadmp.map((item) => (
            <li class="asset-row">
              <span class="asset-title">{item.title}</span>
              <div class="asset-badges">
                <span class:list={['asset-badge', typeClass(item.type)]}>{item.type}</span>
                <span class:list={['asset-prog', progClass(item.programme)]}>{item.programme}</span>
                <span class="asset-format">{item.format}</span>
              </div>
              <a href="#" class="asset-btn">Request access</a>
            </li>
          ))}
        </ul>
      </details>

      <details class="cat-section">
        <summary class="cat-summary">
          <span class="cat-title">SDAMSMP</span>
          <span class="cat-count">6 assets</span>
          <svg class="cat-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <ul class="asset-list">
          {sdamsmp.map((item) => (
            <li class="asset-row">
              <span class="asset-title">{item.title}</span>
              <div class="asset-badges">
                <span class:list={['asset-badge', typeClass(item.type)]}>{item.type}</span>
                <span class:list={['asset-prog', progClass(item.programme)]}>{item.programme}</span>
                <span class="asset-format">{item.format}</span>
              </div>
              <a href="#" class="asset-btn">Request access</a>
            </li>
          ))}
        </ul>
      </details>

      <details class="cat-section">
        <summary class="cat-summary">
          <span class="cat-title">Vision Care Initiative</span>
          <span class="cat-count">4 assets</span>
          <svg class="cat-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <ul class="asset-list">
          {vision.map((item) => (
            <li class="asset-row">
              <span class="asset-title">{item.title}</span>
              <div class="asset-badges">
                <span class:list={['asset-badge', typeClass(item.type)]}>{item.type}</span>
                <span class:list={['asset-prog', progClass(item.programme)]}>{item.programme}</span>
                <span class="asset-format">{item.format}</span>
              </div>
              <a href="#" class="asset-btn">Request access</a>
            </li>
          ))}
        </ul>
      </details>

      <details class="cat-section">
        <summary class="cat-summary">
          <span class="cat-title">Research &amp; Publications</span>
          <span class="cat-count">3 collections</span>
          <svg class="cat-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <ul class="asset-list">
          {publications.map((item) => (
            <li class="asset-row">
              <span class="asset-title">{item.title}</span>
              <div class="asset-badges">
                <span class:list={['asset-badge', typeClass(item.type)]}>{item.type}</span>
                <span class:list={['asset-prog', progClass(item.programme)]}>{item.programme}</span>
                <span class="asset-format asset-format--link">{item.format}</span>
              </div>
              <a href={item.href} class="asset-btn asset-btn--view">View</a>
            </li>
          ))}
        </ul>
      </details>
    </div>
  </section>
</BaseLayout>

<style>
  .search-bar {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    padding-block: 8px;
  }

  .search-input-wrap {
    position: relative;
    flex: 1;
    min-width: 220px;
  }

  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-slate);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 10px 14px 10px 42px;
    border: 1.5px solid var(--color-border-green);
    border-radius: var(--radius-pill);
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-ink);
    background: #fff;
    outline: none;
    transition: border-color var(--dur) var(--ease);
    box-sizing: border-box;
  }

  .search-input:focus {
    border-color: var(--color-institutional);
  }

  .filter-select {
    padding: 10px 14px;
    border: 1.5px solid var(--color-border-green);
    border-radius: var(--radius-pill);
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-ink);
    background: #fff;
    cursor: pointer;
    outline: none;
    transition: border-color var(--dur) var(--ease);
  }

  .filter-select:focus {
    border-color: var(--color-institutional);
  }

  .access-note {
    font-size: 13px;
    color: var(--color-slate);
    margin-top: 14px;
    line-height: 1.6;
  }

  .access-note a {
    color: var(--color-institutional);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .catalogue {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-block: 8px;
  }

  .cat-section {
    border: 1px solid var(--color-border-green);
    border-radius: var(--radius);
    overflow: hidden;
    background: #fff;
    transition: box-shadow var(--dur) var(--ease);
  }

  .cat-section[open] {
    box-shadow: var(--shadow-card-hover);
  }

  .cat-summary {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 24px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background var(--dur) var(--ease);
  }

  .cat-summary::-webkit-details-marker { display: none; }

  .cat-summary:hover { background: var(--color-tint); }

  .cat-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-forest);
    flex: 1;
  }

  .cat-count {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-slate);
  }

  .cat-chevron {
    color: var(--color-slate);
    flex-shrink: 0;
    transition: transform var(--dur) var(--ease);
  }

  .cat-section[open] .cat-chevron {
    transform: rotate(180deg);
  }

  .asset-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-border-green);
  }

  .asset-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 16px;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid var(--color-tint);
    transition: background var(--dur) var(--ease);
  }

  .asset-row:last-child { border-bottom: none; }

  .asset-row:hover { background: var(--color-tint); }

  .asset-title {
    font-size: 14px;
    color: var(--color-ink);
    line-height: 1.5;
  }

  .asset-badges {
    display: flex;
    gap: 6px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .asset-badge {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }

  .badge--policy { background: rgba(20,60,20,0.1); color: var(--color-forest); border: 1px solid rgba(20,60,20,0.2); }
  .badge--research { background: rgba(0,120,60,0.12); color: #00783C; border: 1px solid rgba(0,120,60,0.25); }
  .badge--tech { background: rgba(180,140,40,0.14); color: #8a6a10; border: 1px solid rgba(180,140,40,0.3); }
  .badge--training { background: rgba(74,107,82,0.12); color: var(--color-slate); border: 1px solid rgba(74,107,82,0.2); }
  .badge--legal { background: rgba(212,118,42,0.12); color: #a05010; border: 1px solid rgba(212,118,42,0.25); }
  .badge--doc { background: var(--color-tint); color: var(--color-slate); border: 1px solid var(--color-border-green); }

  .asset-prog {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }

  .prog--nsadmp { background: rgba(20,60,20,0.08); color: var(--color-forest); }
  .prog--sdamsmp { background: rgba(0,120,60,0.08); color: #00783C; }
  .prog--vision { background: rgba(180,140,40,0.1); color: #8a6a10; }
  .prog--inst { background: var(--color-tint); color: var(--color-slate); }

  .asset-format {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    background: #f0f4f1;
    color: var(--color-slate);
    white-space: nowrap;
  }

  .asset-format--link {
    background: rgba(0,120,60,0.1);
    color: #00783C;
  }

  .asset-btn {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    padding: 7px 16px;
    border-radius: var(--radius-pill);
    background: var(--color-tint);
    color: var(--color-institutional);
    border: 1.5px solid var(--color-border-green);
    text-decoration: none;
    white-space: nowrap;
    transition: background var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }

  .asset-btn:hover {
    background: var(--color-institutional);
    color: #fff;
    border-color: var(--color-institutional);
  }

  .asset-btn--view {
    background: var(--color-institutional);
    color: #fff;
    border-color: var(--color-institutional);
  }

  .asset-btn--view:hover {
    background: var(--color-forest);
    border-color: var(--color-forest);
  }

  @media (max-width: 768px) {
    .asset-row {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .asset-badges {
      justify-content: flex-start;
    }

    .search-bar {
      flex-direction: column;
    }

    .search-input-wrap {
      width: 100%;
    }

    .filter-select {
      width: 100%;
    }
  }
</style>
