---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import Button from '@components/Button.astro';
import { site } from '@data/navigation';
const updated = '23 June 2026';

const features = [
  {
    title: 'Keyboard navigation',
    body: 'All interactive elements — menus, forms, buttons, and links — are fully operable using a keyboard alone. A "Skip to content" link appears at the top of every page for keyboard users.'
  },
  {
    title: 'Screen reader support',
    body: 'We use semantic HTML5 elements and ARIA landmarks so screen readers can correctly interpret page structure. Decorative images carry empty alt text; informative images carry descriptive alternatives.'
  },
  {
    title: 'Colour contrast',
    body: 'Text and interactive elements meet the WCAG 2.1 AA minimum contrast ratio of 4.5:1 against their backgrounds. Our primary foreground colours have been verified with the APCA contrast algorithm.'
  },
  {
    title: 'Resizable text',
    body: 'The site remains fully functional when browser text is scaled up to 200%. We use relative units (rem, em) throughout so page layout reflows gracefully.'
  },
  {
    title: 'Focus indicators',
    body: 'Visible focus rings are displayed on all interactive elements. We do not suppress the browser\'s default outline without providing a clear custom alternative.'
  },
  {
    title: 'Motion preferences',
    body: 'Animated elements respect the prefers-reduced-motion media query. Users who request reduced motion see static alternatives for scroll animations and hero transitions.'
  },
  {
    title: 'Form accessibility',
    body: 'All form inputs have associated labels, descriptive placeholder text, and clear inline validation messages. Required fields are indicated both visually and programmatically.'
  },
  {
    title: 'Language declaration',
    body: 'Each page carries a lang="en" attribute so assistive technologies apply correct pronunciation rules. Bengali-language content is marked with lang="bn".'
  },
];

const limitations = [
  'Some older PDF documents (pre-2022 annual reports) may not be fully tagged for screen reader use. We are progressively remediating these files.',
  'Third-party embeds — such as map iframes — may not meet our accessibility standard. We note this inline where relevant.',
];
---
<BaseLayout
  title="Accessibility Statement"
  description="CHRSD's commitment to digital accessibility — WCAG 2.1 AA compliance, features, limitations, and how to request assistance."
>
  <PageHero
    overline="Legal · Accessibility"
    title="Accessibility Statement"
    lead="We are committed to making this website usable by everyone, regardless of ability or technology. This statement describes our current conformance level and how to reach us if you encounter a barrier."
  />

  <!-- COMMITMENT -->
  <section class="section">
    <div class="container">
      <div class="commit">
        <div class="commit__text">
          <p class="overline">Our commitment</p>
          <h2>WCAG 2.1 Level AA</h2>
          <p class="lead">
            CHRSD targets conformance with the Web Content Accessibility Guidelines
            (WCAG) 2.1 at Level AA — the international benchmark for accessible web
            content. This site was built from the ground up with accessibility as a
            design requirement, not an afterthought.
          </p>
          <p>
            We conduct periodic accessibility audits, use automated testing tools, and
            welcome feedback from users with disabilities to identify and address gaps.
            This statement was last reviewed on <strong>{updated}</strong>.
          </p>
        </div>
        <div class="commit__badge" aria-hidden="true">
          <span class="badge__level">AA</span>
          <span class="badge__standard">WCAG 2.1</span>
          <span class="badge__note">Targeted conformance</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section section--alt">
    <div class="container">
      <p class="overline">What we've built</p>
      <h2>Accessibility features</h2>
      <p class="lead" style="margin-top:14px;max-width:60ch;color:var(--color-slate)">
        The following features are present throughout the site to reduce barriers for users
        with a wide range of disabilities and assistive technologies.
      </p>
      <div class="features">
        {features.map((f) => (
          <article class="feature">
            <span class="feature__rule" aria-hidden="true"></span>
            <h3 class="feature__title">{f.title}</h3>
            <p class="feature__body">{f.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- KNOWN LIMITATIONS -->
  <section class="section">
    <div class="container">
      <div class="limits">
        <div>
          <p class="overline">Known limitations</p>
          <h2>Where we fall short</h2>
          <p style="margin-top:14px;color:var(--color-slate)">
            Despite our best efforts, some content may not fully meet WCAG 2.1 AA. We are
            working to address these issues in a prioritised manner.
          </p>
          <ul class="limit__list">
            {limitations.map((l) => <li>{l}</li>)}
          </ul>
        </div>
        <div class="feedback">
          <p class="overline">Encountered a barrier?</p>
          <h3>We want to hear from you</h3>
          <p>
            If you experience an accessibility barrier on this site, please contact us
            directly. We will work to provide the information in an alternative format
            or address the underlying issue as quickly as possible.
          </p>
          <div style="margin-top:24px;display:flex;flex-wrap:wrap;gap:12px">
            <Button href="/get-involved/contact-us/" variant="solid">Contact us</Button>
            <Button href={`mailto:${site.email}`} variant="outline">Email directly</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TECH USED -->
  <section class="section section--dark">
    <div class="container">
      <p class="overline">Technical approach</p>
      <h2>How we build for accessibility</h2>
      <div class="tech">
        <p>
          This site is built with <strong>Astro</strong>, a static site framework that
          produces clean, standards-compliant HTML with zero JavaScript by default.
          Pages are server-rendered to static HTML, which ensures that content is
          accessible even when JavaScript is unavailable.
        </p>
        <p>
          We test using <strong>VoiceOver</strong> on macOS/iOS, <strong>NVDA</strong>
          on Windows, and <strong>axe DevTools</strong> for automated audits. Colour
          contrast is validated with <strong>Colour Contrast Analyser</strong> and the
          <strong>APCA</strong> algorithm.
        </p>
        <p>
          Our design token system enforces a consistent type scale, spacing grid, and
          colour palette — reducing the risk of one-off accessibility regressions.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Commitment split */
  .commit {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 56px;
    align-items: start;
  }
  .commit__text h2 { margin-top: 12px; }
  .commit__text p + p { margin-top: 16px; color: var(--color-slate); }
  .commit__badge {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    width: 160px; height: 160px; border-radius: 50%;
    border: 3px solid var(--color-institutional);
    background: var(--color-tint);
    flex-shrink: 0;
    gap: 2px;
  }
  .badge__level {
    font-family: var(--font-display); font-weight: 800; font-size: 48px;
    color: var(--color-institutional); line-height: 1;
  }
  .badge__standard {
    font-family: var(--font-display); font-weight: 600; font-size: 14px;
    color: var(--color-forest);
  }
  .badge__note {
    font-size: 11px; color: var(--color-slate); text-align: center;
    max-width: 100px; line-height: 1.3; margin-top: 4px;
  }

  /* Features grid */
  .features {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 40px;
  }
  .feature { background: #fff; border: 1px solid var(--color-border-green); border-radius: var(--radius); padding: 26px; }
  .feature__rule { display: block; width: 40px; height: 3px; background: var(--color-gold); border-radius: 2px; }
  .feature__title { font-size: 17px; color: var(--color-forest); margin: 14px 0 10px; }
  .feature__body { font-size: 15px; color: var(--color-slate); line-height: 1.65; }

  /* Limitations */
  .limits { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; }
  .limit__list {
    margin-top: 20px; padding-left: 20px; display: flex; flex-direction: column; gap: 12px;
  }
  .limit__list li { color: var(--color-slate); line-height: 1.7; }
  .feedback {
    background: var(--color-tint); border: 1px solid var(--color-border-green);
    border-radius: var(--radius); padding: 34px;
  }
  .feedback h3 { margin: 12px 0 16px; color: var(--color-forest); }
  .feedback p { color: var(--color-slate); line-height: 1.7; }

  /* Tech section */
  .section--dark h2 { color: #fff; margin-top: 14px; }
  .tech { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; margin-top: 36px; }
  .tech p { color: rgba(255,255,255,0.82); line-height: 1.75; }
  .tech strong { color: #fff; }

  @media (max-width: 1100px) {
    .features { grid-template-columns: repeat(2, 1fr); }
    .tech { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 860px) {
    .commit { grid-template-columns: 1fr; }
    .commit__badge { margin: 0 auto; }
    .limits { grid-template-columns: 1fr; gap: 32px; }
    .tech { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .features { grid-template-columns: 1fr; }
  }
</style>
